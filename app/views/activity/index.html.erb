<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold text-slate-900"><%= t("activity.title") %></h1>
  </div>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
      <p class="text-sm font-medium text-slate-700">
        <%= t("activity.summary", count: number_with_delimiter(@graph.total), period: @period) %>
      </p>

      <div class="flex flex-wrap items-center gap-2">
        <%# botões de período %>
        <% { "3m" => 3, "6m" => 6, "12m" => 12 }.each do |key, months| %>
          <% active = @year.nil? && @range == key %>
          <%= link_to t("activity.months", count: months), activity_path(range: key),
                class: "rounded-lg px-3 py-1.5 text-xs font-medium #{active ? 'bg-emerald-600 text-white' : 'border border-slate-300 text-slate-600 hover:bg-slate-50'}" %>
        <% end %>

        <%# seleção por ano %>
        <%= form_with url: activity_path, method: :get, class: "inline" do |f| %>
          <%= f.select :year,
                options_for_select([[t("activity.by_year"), ""]] + @years.map { |y| [y.to_s, y] }, @year),
                {},
                onchange: "this.form.requestSubmit()",
                class: "rounded-lg border px-3 py-1.5 text-xs font-medium #{@year ? 'border-emerald-600 bg-emerald-600 text-white' : 'border-slate-300 text-slate-600'}" %>
        <% end %>
      </div>
    </div>

    <%= render "shared/contributions", graph: @graph %>
  </section>
</div>
