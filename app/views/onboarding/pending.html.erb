<div class="mx-auto max-w-xl py-12 text-center">
  <h1 class="mb-3 text-2xl font-bold text-slate-900"><%= t("onboarding.pending_title") %></h1>
  <p class="mb-6 text-slate-500"><%= t("onboarding.pending_intro") %></p>

  <% if @pending.present? && @pending.any? %>
    <div class="inline-block rounded-xl border border-slate-200 bg-white p-4 text-left shadow-sm">
      <ul class="list-inside list-disc text-sm text-slate-700">
        <% @pending.each do |m| %>
          <li><%= t("onboarding.pending_item", account: m.account.name) %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-8 space-x-4">
    <%= link_to t("onboarding.create_own"), new_account_path, class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
    <%= link_to t("onboarding.join_other"), new_join_request_path, class: "text-sm text-emerald-600 hover:underline" %>
  </div>
</div>
