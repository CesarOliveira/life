<div class="max-w-xl mx-auto text-center py-12">
  <h1 class="text-2xl font-bold mb-3">Aguardando aprovação</h1>
  <p class="text-gray-600 mb-6">Sua solicitação foi enviada. Um administrador da conta precisa aprovar seu acesso.</p>

  <% if @pending.present? && @pending.any? %>
    <div class="bg-white shadow rounded p-4 text-left inline-block">
      <ul class="text-sm text-gray-700 list-disc list-inside">
        <% @pending.each do |m| %>
          <li><%= m.account.name %> — pendente</li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-8 space-x-4">
    <%= link_to "Criar minha própria conta", new_account_path, class: "bg-indigo-600 text-white px-4 py-2 rounded text-sm font-semibold" %>
    <%= link_to "Entrar com outro código", new_join_request_path, class: "text-sm text-indigo-600 hover:underline" %>
  </div>
</div>
