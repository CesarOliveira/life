<div class="mx-auto max-w-2xl">
  <h1 class="mb-2 text-2xl font-bold text-slate-900"><%= t("onboarding.welcome") %></h1>
  <p class="mb-8 text-slate-500"><%= t("onboarding.intro") %></p>

  <div class="grid gap-6 md:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-slate-900"><%= t("onboarding.create_account") %></h2>
      <%= form_with model: @account, url: accounts_path, method: :post, class: "space-y-4" do |f| %>
        <% if @account.errors.any? %>
          <div class="rounded-lg border border-rose-200 bg-rose-50 p-2 text-sm text-rose-700">
            <%= @account.errors.full_messages.to_sentence %>
          </div>
        <% end %>
        <div>
          <%= f.label :name, Account.human_attribute_name(:name), class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= f.text_field :name, required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
        </div>
        <%= f.submit t("accounts.create"), class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
      <% end %>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-slate-900"><%= t("onboarding.join_account") %></h2>
      <p class="mb-4 text-sm text-slate-500"><%= t("onboarding.join_intro") %></p>
      <%= link_to t("onboarding.join_cta"), new_join_request_path, class: "inline-block rounded-lg bg-slate-800 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-900" %>
    </div>
  </div>

  <% if @pending.present? && @pending.any? %>
    <div class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-4">
      <h3 class="mb-2 font-semibold text-amber-800"><%= t("onboarding.pending_requests") %></h3>
      <ul class="list-inside list-disc text-sm text-amber-800">
        <% @pending.each do |m| %>
          <li><%= t("onboarding.pending_waiting", account: m.account.name) %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
