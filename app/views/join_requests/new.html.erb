<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold mb-6">Entrar em uma conta</h1>

  <%= form_with url: join_requests_path, method: :post, class: "bg-white shadow rounded p-6 space-y-4" do |f| %>
    <p class="text-sm text-gray-600">Informe o código de convite fornecido por um administrador da conta.</p>
    <div>
      <%= label_tag :join_code, "Código de convite", class: "block text-sm font-medium mb-1" %>
      <%= text_field_tag :join_code, params[:join_code], required: true, class: "w-full border rounded px-3 py-2 text-sm font-mono" %>
    </div>
    <div class="flex items-center gap-3">
      <%= submit_tag "Solicitar entrada", class: "bg-indigo-600 text-white px-4 py-2 rounded text-sm font-semibold" %>
      <%= link_to "Voltar", onboarding_path, class: "text-sm text-gray-500 hover:underline" %>
    </div>
  <% end %>
</div>
