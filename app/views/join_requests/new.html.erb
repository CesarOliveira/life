<div class="mx-auto max-w-md">
  <h1 class="mb-6 text-2xl font-bold text-slate-900"><%= t("join_requests.title") %></h1>

  <%= form_with url: join_requests_path, method: :post, class: "space-y-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |f| %>
    <p class="text-sm text-slate-500"><%= t("join_requests.intro") %></p>
    <div>
      <%= label_tag :join_code, t("join_requests.code_label"), class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= text_field_tag :join_code, params[:join_code], required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 font-mono text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
    </div>
    <div class="flex items-center gap-3">
      <%= submit_tag t("join_requests.submit"), class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
      <%= link_to t("join_requests.back"), onboarding_path, class: "text-sm text-slate-500 hover:underline" %>
    </div>
  <% end %>
</div>
