<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t("setup.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("setup.intro") %></p>
  </div>

  <%# Token (mascarado; busca o inteiro só ao copiar) %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
           data-controller="clipboard"
           data-clipboard-copied-value="<%= t('setup.copied') %>"
           data-clipboard-label-value="<%= t('setup.copy') %>"
           data-clipboard-fetch-url-value="<%= screen_time_token_path %>">
    <p class="mb-1 text-xs font-medium text-slate-600"><%= t("setup.token_label") %></p>
    <div class="flex items-stretch gap-2">
      <code class="block flex-1 break-all rounded-lg bg-slate-100 px-3 py-2 text-xs text-slate-700"><%= masked_token(@token) %></code>
      <button type="button" data-clipboard-target="button" data-action="clipboard#copy"
              class="shrink-0 rounded-lg bg-emerald-600 px-3 text-xs font-semibold text-white hover:bg-emerald-700"><%= t("setup.copy") %></button>
    </div>
    <p class="mt-1 text-xs text-amber-600"><%= t("setup.keep_secret") %></p>
  </section>

  <div class="space-y-6" data-controller="checklist">
    <%# 1. Saúde %>
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="mb-4 font-semibold text-slate-900"><%= t("setup.health_section") %></h2>
      <ul class="space-y-4">
        <li class="flex gap-3" data-checklist-row>
          <input type="checkbox" data-checklist-target="item" data-key="copy_token" data-action="change->checklist#toggle"
                 class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
          <div class="flex-1">
            <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.copy_token") %></p>
          </div>
        </li>

        <li class="flex gap-3" data-checklist-row>
          <input type="checkbox" data-checklist-target="item" data-key="install_health" data-action="change->checklist#toggle"
                 class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
          <div class="flex-1" data-controller="clipboard" data-clipboard-fetch-url-value="<%= screen_time_token_path %>">
            <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.install_health") %></p>
            <p class="mt-0.5 text-xs text-slate-500"><%= t("setup.steps.install_health_help") %></p>
            <div class="mt-2 flex items-center gap-2">
              <%= link_to t("setup.steps.download_health"), health_shortcut_path(v: @health_version),
                    data: { action: "clipboard#copy" },
                    class: "inline-block rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-700" %>
              <span data-clipboard-target="feedback" class="hidden text-xs font-medium text-emerald-700"><%= t("setup.token_copied") %></span>
            </div>
          </div>
        </li>

        <li class="flex gap-3" data-checklist-row>
          <input type="checkbox" data-checklist-target="item" data-key="automation_health" data-action="change->checklist#toggle"
                 class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
          <div class="flex-1">
            <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.automation_health") %></p>
            <p class="mt-0.5 text-xs text-slate-500"><%= t("setup.automation_help") %></p>
          </div>
        </li>
      </ul>
    </section>

    <%# 2. Tempo de tela %>
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="mb-4 font-semibold text-slate-900"><%= t("setup.screen_section") %></h2>
      <ul class="space-y-4">
        <li class="flex gap-3" data-checklist-row>
          <input type="checkbox" data-checklist-target="item" data-key="screen_setup" data-action="change->checklist#toggle"
                 class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
          <div class="flex-1">
            <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.screen_setup") %></p>
            <p class="mt-0.5 text-xs text-slate-500"><%= t("setup.steps.screen_setup_help") %></p>
            <p class="mt-2 text-xs font-medium text-slate-600"><%= t("setup.endpoint_label") %></p>
            <code class="mt-1 block break-all rounded-lg bg-slate-100 px-3 py-2 text-xs text-slate-700"><%= @endpoint %></code>
          </div>
        </li>

        <li class="flex gap-3" data-checklist-row>
          <input type="checkbox" data-checklist-target="item" data-key="automation_screen" data-action="change->checklist#toggle"
                 class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
          <div class="flex-1">
            <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.automation_screen") %></p>
            <p class="mt-0.5 text-xs text-slate-500"><%= t("setup.automation_help") %></p>
          </div>
        </li>
      </ul>
    </section>
  </div>

  <p class="text-center text-xs text-slate-400"><%= t("setup.progress") %></p>
  <p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-center text-xs text-slate-500"><%= t("setup.combined_note") %></p>
</div>
