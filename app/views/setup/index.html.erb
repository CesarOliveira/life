<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t("setup.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("setup.intro") %></p>
  </div>

  <%# Token (mascarado; busca o inteiro só ao copiar) %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
           data-controller="clipboard"
           data-clipboard-copied-value="<%= t('setup.copied') %>"
           data-clipboard-label-value="<%= t('setup.copy') %>"
           data-clipboard-fetch-url-value="<%= screen_time_token_path %>">
    <p class="mb-1 text-xs font-medium text-slate-600"><%= t("setup.token_label") %></p>
    <div class="flex items-stretch gap-2">
      <code class="block flex-1 break-all rounded-lg bg-slate-100 px-3 py-2 text-xs text-slate-700"><%= masked_token(@token) %></code>
      <button type="button" data-clipboard-target="button" data-action="clipboard#copy"
              class="shrink-0 rounded-lg bg-emerald-600 px-3 text-xs font-semibold text-white hover:bg-emerald-700"><%= t("setup.copy") %></button>
    </div>
    <p class="mt-1 text-xs text-amber-600"><%= t("setup.keep_secret") %></p>
    <div class="mt-3 border-t border-slate-100 pt-3">
      <%= button_to t("setup.regenerate"), regenerate_screen_time_token_path, method: :post,
            class: "rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50",
            form: { data: { turbo_confirm: t("setup.regenerate_confirm") } } %>
      <p class="mt-1 text-xs text-slate-400"><%= t("setup.regenerate_hint") %></p>
    </div>
  </section>

  <%# Fluxo único: o atalho Life faz tudo (Saúde + Tempo de tela) %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm" data-controller="checklist">
    <h2 class="mb-1 font-semibold text-slate-900"><%= t("setup.shortcut_section") %></h2>
    <p class="mb-4 text-xs text-slate-500"><%= t("setup.shortcut_hint") %></p>

    <ul class="space-y-4">
      <li class="flex gap-3" data-checklist-row>
        <input type="checkbox" data-checklist-target="item" data-key="copy_token" data-action="change->checklist#toggle"
               class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
        <p class="flex-1 text-sm font-medium text-slate-800"><%= t("setup.steps.copy_token") %></p>
      </li>

      <li class="flex gap-3" data-checklist-row>
        <input type="checkbox" data-checklist-target="item" data-key="install" data-action="change->checklist#toggle"
               class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
        <% if cookies[:life_app].present? %>
          <%# No app: instala com o token JÁ embutido (lifeapp://install-shortcut
              é interceptado pelo app, que busca /api/shortcut via Bearer e abre). %>
          <div class="flex-1">
            <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.install") %></p>
            <p class="mt-0.5 text-xs text-slate-500"><%= t("setup.steps.install_help_app") %></p>
            <%= link_to t("setup.steps.install_app"), "lifeapp://install-shortcut",
                  class: "mt-2 inline-block rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-700" %>
          </div>
        <% else %>
          <div class="flex-1" data-controller="clipboard" data-clipboard-fetch-url-value="<%= screen_time_token_path %>">
            <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.install") %></p>
            <p class="mt-0.5 text-xs text-slate-500"><%= t("setup.steps.install_help") %></p>
            <div class="mt-2 flex items-center gap-2">
              <%= link_to t("setup.steps.download"), health_shortcut_path(v: @health_version),
                    data: { action: "clipboard#copy" },
                    class: "inline-block rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-700" %>
              <span data-clipboard-target="feedback" class="hidden text-xs font-medium text-emerald-700"><%= t("setup.token_copied") %></span>
            </div>
          </div>
        <% end %>
      </li>

      <li class="flex gap-3" data-checklist-row>
        <input type="checkbox" data-checklist-target="item" data-key="automation" data-action="change->checklist#toggle"
               class="mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-emerald-600">
        <div class="flex-1">
          <p class="text-sm font-medium text-slate-800"><%= t("setup.steps.automation") %></p>
          <p class="mt-0.5 text-xs text-slate-500"><%= t("setup.automation_help") %></p>
        </div>
      </li>
    </ul>

    <%# Atalho: rodar sob demanda (dispara o Shortcuts em foreground). Útil se a
        automação diária falhou. A automação continua sendo o disparo automático. %>
    <div class="mt-4 border-t border-slate-100 pt-4">
      <%= link_to t("setup.run_now"), @shortcut_run_url,
            class: "inline-flex items-center gap-2 rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50" %>
      <p class="mt-1 text-xs text-slate-400"><%= t("setup.run_now_hint") %></p>
    </div>
  </section>

  <%# Conectores: integrações que puxam dados sozinhas %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="mb-1 font-semibold text-slate-900"><%= t("connectors.title") %></h2>
    <p class="mb-4 text-xs text-slate-500"><%= t("connectors.hint") %></p>

    <div class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-slate-200 p-4">
      <div class="min-w-0">
        <p class="flex items-center gap-2 font-medium text-slate-800">
          <svg viewBox="0 0 16 16" class="h-5 w-5 fill-slate-800" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.5 7.5 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
          GitHub
          <% if @github_connector %>
            <% ok = @github_connector.status == "active" %>
            <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold <%= ok ? "bg-emerald-100 text-emerald-700" : "bg-rose-100 text-rose-700" %>">
              <%= t("connectors.statuses.#{@github_connector.status}") %>
            </span>
          <% end %>
        </p>
        <% if @github_connector %>
          <p class="mt-0.5 text-xs text-slate-500">
            @<%= @github_connector.login %> ·
            <%= @github_connector.last_synced_at ? t("connectors.last_sync", time: l(@github_connector.last_synced_at, format: :short)) : t("connectors.never_synced") %>
            <% if @github_connector.last_points.positive? %>· <%= t("connectors.points", count: @github_connector.last_points) %><% end %>
          </p>
          <% if @github_connector.last_error.present? %>
            <p class="mt-0.5 text-xs text-rose-600"><%= @github_connector.last_error %></p>
          <% end %>
        <% else %>
          <p class="mt-0.5 text-xs text-slate-500"><%= t("connectors.github_desc") %></p>
        <% end %>
      </div>

      <div class="flex shrink-0 items-center gap-2">
        <% if @github_connector %>
          <%= button_to t("connectors.sync_now"), sync_connector_path(@github_connector), method: :post,
                class: "cursor-pointer rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50" %>
          <%= button_to t("connectors.disconnect"), connector_path(@github_connector), method: :delete,
                class: "cursor-pointer rounded-lg border border-rose-200 px-3 py-1.5 text-xs font-medium text-rose-600 hover:bg-rose-50",
                form: { data: { turbo_confirm: t("connectors.disconnect_confirm") } } %>
        <% elsif Connectors::Github.configured? %>
          <%= button_to t("connectors.connect_github"), github_connect_connectors_path, method: :post,
                class: "cursor-pointer rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
        <% else %>
          <p class="text-xs text-amber-600"><%= t("connectors.not_configured") %></p>
        <% end %>
      </div>
    </div>
  </section>

  <p class="text-center text-xs text-slate-400"><%= t("setup.progress") %></p>
</div>
