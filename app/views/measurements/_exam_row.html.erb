<%# locals: item ({type:, latest:, rows:, chart:}), group — linha expansível de um exame. %>
<% latest = item[:latest] %>
<tbody data-controller="accordion" data-filter-target="item"
       data-filter-name="<%= item[:type].name %> <%= item[:type].aliases.join(' ') %>"
       data-filter-group="<%= group.key %>"
       class="border-t border-slate-100">
  <tr class="cursor-pointer hover:bg-slate-50" data-action="click->accordion#toggle">
    <td class="px-4 py-2.5 font-medium text-slate-900">
      <span data-accordion-target="chevron" class="mr-1 inline-block text-slate-400 transition-transform">›</span>
      <%= item[:type].name %>
    </td>
    <td class="px-4 py-2.5 text-right font-semibold text-slate-900">
      <%= number_with_delimiter(latest.display_value) %> <span class="font-normal text-slate-400"><%= latest.unit %></span>
    </td>
    <td class="px-4 py-2.5">
      <% if latest.reference? %>
        <% if latest.out_of_range? %>
          <span class="rounded-full bg-rose-100 px-2 py-0.5 text-xs font-semibold text-rose-700"><%= t("measurements.out_of_range") %></span>
        <% else %>
          <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700"><%= t("measurements.in_range") %></span>
        <% end %>
      <% else %>
        <span class="text-xs text-slate-300">—</span>
      <% end %>
    </td>
    <td class="px-4 py-2.5 text-xs text-slate-500">
      <%= latest.reference? ? "#{latest.ref_low&.to_f || '—'}–#{latest.ref_high&.to_f || '—'}" : "—" %>
    </td>
    <td class="px-4 py-2.5 text-xs text-slate-500"><%= latest.measured_on.strftime("%d/%m/%Y") %></td>
  </tr>
  <tr data-accordion-target="panel" class="hidden">
    <td colspan="5" class="bg-slate-50/60 px-4 py-4">
      <% if item[:type].description.present? %>
        <p class="mb-3 text-xs text-slate-500"><%= item[:type].description %></p>
      <% end %>
      <% if item[:chart].any? %>
        <div class="mb-4 rounded-xl border border-slate-200 bg-white p-3">
          <%= render "chart", chart: item[:chart], unit: latest.unit %>
        </div>
      <% end %>
      <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-left text-xs font-medium uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-3 py-2"><%= t("measurements.table.date") %></th>
              <th class="px-3 py-2 text-right"><%= t("measurements.table.value") %></th>
              <th class="px-3 py-2"><%= t("measurements.table.reference") %></th>
              <th class="px-3 py-2"><%= t("measurements.table.source") %></th>
              <th class="px-3 py-2"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% item[:rows].each do |r| %>
              <tr>
                <td class="px-3 py-1.5 text-slate-500"><%= r.measured_on.strftime("%d/%m/%Y") %></td>
                <td class="px-3 py-1.5 text-right font-medium <%= "text-rose-600" if r.out_of_range? %>">
                  <%= number_with_delimiter(r.display_value) %> <span class="font-normal text-slate-400"><%= r.unit %></span>
                </td>
                <td class="px-3 py-1.5 text-xs text-slate-500"><%= r.reference? ? "#{r.ref_low&.to_f || '—'}–#{r.ref_high&.to_f || '—'}" : "—" %></td>
                <td class="px-3 py-1.5 text-xs text-slate-400"><%= r.source %></td>
                <td class="px-3 py-1.5 text-right">
                  <%= button_to t("memberships.remove"), exam_result_path(r), method: :delete,
                        class: "text-xs text-rose-600 hover:underline",
                        form: { data: { turbo_confirm: t("measurements.remove_confirm") } } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </td>
  </tr>
</tbody>
