<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold text-slate-900"><%= t("measurements.title") %></h1>
    <%# Abas: sinais / exames %>
    <div class="inline-flex items-center overflow-hidden rounded-lg border border-slate-200 text-sm">
      <% Measurement::CATEGORIES.each do |cat| %>
        <%= link_to t("measurements.tabs.#{cat}"), measurements_path(category: cat),
              class: "px-4 py-1.5 #{@category == cat ? "bg-emerald-600 text-white font-semibold" : "text-slate-500 hover:bg-slate-50"}" %>
      <% end %>
    </div>
  </div>

  <% if @category == "health" %>
    <%# Peso (mora dentro da Saúde) %>
    <%= render "weights/panel", entry: @weight_entry, latest: @weight_latest, chart: @weight_chart, entries: @weight_entries %>

    <%# Entrada manual de sinais %>
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="mb-3 font-semibold text-slate-900"><%= t("measurements.add") %></h2>
      <%= form_with model: @measurement, url: measurements_path, method: :post, class: "flex flex-wrap items-end gap-3" do |f| %>
        <% if @measurement.errors.any? %>
          <div class="w-full rounded-lg border border-rose-200 bg-rose-50 p-2 text-sm text-rose-700">
            <%= @measurement.errors.full_messages.to_sentence %>
          </div>
        <% end %>
        <div>
          <%= f.label :key, t("measurements.metric"), class: "mb-1 block text-xs font-medium text-slate-600" %>
          <%= f.select :key,
                options_for_select(@catalog_keys.map { |k| [Measurement.key_label(k), k] }, @measurement.key),
                {},
                class: "rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
        </div>
        <div>
          <%= f.label :value, t("measurements.value"), class: "mb-1 block text-xs font-medium text-slate-600" %>
          <%= f.number_field :value, step: "any", required: true, class: "w-28 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
        </div>
        <div>
          <%= f.label :measured_on, t("measurements.date"), class: "mb-1 block text-xs font-medium text-slate-600" %>
          <%= f.date_field :measured_on, class: "rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
        </div>
        <%= f.submit t("measurements.add"), class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
      <% end %>
    </section>

    <% if @groups.empty? %>
      <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center text-slate-500 shadow-sm">
        <%= t("measurements.empty") %>
      </div>
    <% else %>
      <div class="grid gap-4 lg:grid-cols-2">
        <% @groups.each do |g| %>
          <%= render "metric_card", g: g, category: @category %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <%# ===== Aba Exames (ExamResult / catálogo ExamType) ===== %>
    <div data-controller="filter" class="space-y-6">
      <%# Barra: filtro à esquerda, ações (modais) à direita %>
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap items-center gap-2">
          <input type="search" data-filter-target="query" data-action="input->filter#apply"
                 placeholder="<%= t("measurements.filter_placeholder") %>"
                 class="w-48 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500">
          <select data-filter-target="group" data-action="change->filter#apply"
                  class="rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500">
            <option value=""><%= t("measurements.all_groups") %></option>
            <% @exam_groups.each do |entry| %>
              <option value="<%= entry[:group].key %>"><%= entry[:group].name %></option>
            <% end %>
          </select>
        </div>

        <div class="flex items-center gap-2">
          <%# Modal: adicionar métrica %>
          <div data-controller="modal">
            <button type="button" data-action="modal#open"
                    class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">+ <%= t("measurements.add") %></button>
            <dialog data-modal-target="dialog" data-action="click->modal#backdrop"
                    class="w-full max-w-lg rounded-2xl p-0 shadow-xl backdrop:bg-slate-900/40">
              <div class="p-5">
                <div class="mb-4 flex items-center justify-between">
                  <h3 class="font-semibold text-slate-900"><%= t("measurements.add_exam_title") %></h3>
                  <button type="button" data-action="modal#close" class="text-slate-400 hover:text-slate-600">✕</button>
                </div>
                <%= form_with model: @exam_result, url: exam_results_path, method: :post, class: "space-y-3" do |f| %>
                  <div>
                    <%= f.label :exam_type_id, t("measurements.metric"), class: "mb-1 block text-xs font-medium text-slate-600" %>
                    <%= f.select :exam_type_id,
                          options_for_select(@exam_types.map { |type| [type.name, type.id] }, @exam_result.exam_type_id),
                          {},
                          class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
                  </div>
                  <div class="grid grid-cols-3 gap-3">
                    <div>
                      <%= f.label :value, t("measurements.value"), class: "mb-1 block text-xs font-medium text-slate-600" %>
                      <%= f.number_field :value, step: "any", required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
                    </div>
                    <div>
                      <%= f.label :unit, t("measurements.unit"), class: "mb-1 block text-xs font-medium text-slate-600" %>
                      <%= f.text_field :unit, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
                    </div>
                    <div>
                      <%= f.label :measured_on, t("measurements.date"), class: "mb-1 block text-xs font-medium text-slate-600" %>
                      <%= f.date_field :measured_on, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
                    </div>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <%= f.label :ref_low, t("measurements.ref_low"), class: "mb-1 block text-xs font-medium text-slate-600" %>
                      <%= f.number_field :ref_low, step: "any", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
                    </div>
                    <div>
                      <%= f.label :ref_high, t("measurements.ref_high"), class: "mb-1 block text-xs font-medium text-slate-600" %>
                      <%= f.number_field :ref_high, step: "any", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
                    </div>
                  </div>
                  <div class="flex justify-end gap-2 pt-2">
                    <button type="button" data-action="modal#close" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50"><%= t("habits.cancel") %></button>
                    <%= f.submit t("measurements.add"), class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
                  </div>
                <% end %>
              </div>
            </dialog>
          </div>

          <%# Modal: importar PDF %>
          <div data-controller="modal">
            <button type="button" data-action="modal#open"
                    class="rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700"><%= t("measurements.pdf.submit") %></button>
            <dialog data-modal-target="dialog" data-action="click->modal#backdrop"
                    class="w-full max-w-lg rounded-2xl p-0 shadow-xl backdrop:bg-slate-900/40">
              <div class="p-5">
                <div class="mb-2 flex items-center justify-between">
                  <h3 class="font-semibold text-slate-900"><%= t("measurements.pdf.title") %></h3>
                  <button type="button" data-action="modal#close" class="text-slate-400 hover:text-slate-600">✕</button>
                </div>
                <p class="mb-4 text-xs text-slate-500"><%= t("measurements.pdf.intro") %></p>
                <% if @pdf_import %>
                  <%= form_with url: import_measurements_path, method: :post, multipart: true, class: "space-y-4" do %>
                    <%# accept por extensão (".pdf") — no iOS/PWA o accept por MIME às vezes impede o seletor de abrir. %>
                    <%= file_field_tag :file, accept: ".pdf", required: true,
                          class: "w-full text-sm file:mr-3 file:rounded-lg file:border-0 file:bg-emerald-50 file:px-3 file:py-2 file:text-sm file:font-medium file:text-emerald-700 hover:file:bg-emerald-100" %>
                    <div class="flex justify-end gap-2">
                      <button type="button" data-action="modal#close" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50"><%= t("habits.cancel") %></button>
                      <%= submit_tag t("measurements.pdf.submit"),
                            data: { turbo_submits_with: t("measurements.pdf.processing") },
                            class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
                    </div>
                  <% end %>
                <% else %>
                  <p class="rounded-lg border border-amber-200 bg-amber-50 p-2 text-xs text-amber-700"><%= t("measurements.pdf.errors.not_configured") %></p>
                <% end %>
              </div>
            </dialog>
          </div>
        </div>
      </div>

      <% if @exam_groups.empty? %>
        <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center text-slate-500 shadow-sm">
          <%= t("measurements.empty") %>
        </div>
      <% else %>
        <p class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-xs text-slate-500"><%= t("measurements.ref_note") %></p>

        <%# Grupos como tabelas; cada exame é uma linha expansível (accordeon) %>
        <% @exam_groups.each do |entry| %>
          <section data-filter-target="section" class="space-y-2">
            <h2 class="text-lg font-bold text-slate-900"><%= entry[:group].name %></h2>
            <% if entry[:group].description.present? %>
              <p class="text-xs text-slate-500"><%= entry[:group].description %></p>
            <% end %>
            <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm">
              <table class="min-w-full text-sm">
                <thead class="bg-slate-50 text-left text-xs font-medium uppercase tracking-wide text-slate-500">
                  <tr>
                    <th class="px-4 py-2.5"><%= t("measurements.table.exam") %></th>
                    <th class="px-4 py-2.5 text-right"><%= t("measurements.table.value") %></th>
                    <th class="px-4 py-2.5"><%= t("measurements.table.status") %></th>
                    <th class="px-4 py-2.5"><%= t("measurements.table.reference") %></th>
                    <th class="px-4 py-2.5"><%= t("measurements.table.date") %></th>
                  </tr>
                </thead>
                <% entry[:items].each do |item| %>
                  <%= render "exam_row", item: item, group: entry[:group] %>
                <% end %>
              </table>
            </div>
          </section>
        <% end %>
        <p data-filter-target="empty" class="hidden rounded-2xl border border-slate-200 bg-white p-8 text-center text-sm text-slate-500 shadow-sm"><%= t("measurements.no_matches") %></p>

        <%# Zona de perigo: apagar tudo com modal + digitar DELETE %>
        <div data-controller="modal" class="border-t border-slate-200 pt-4 text-center">
          <button type="button" data-action="modal#open" class="text-xs font-medium text-rose-600 hover:underline"><%= t("measurements.clear_exams") %></button>
          <dialog data-modal-target="dialog" data-action="click->modal#backdrop"
                  class="w-full max-w-md rounded-2xl p-0 shadow-xl backdrop:bg-slate-900/40">
            <div class="p-5 text-left" data-controller="type-to-confirm">
              <h3 class="font-semibold text-rose-700"><%= t("measurements.clear_exams") %></h3>
              <p class="mt-2 text-sm text-slate-600"><%= t("measurements.clear_exams_confirm2") %></p>
              <%= form_with url: destroy_exams_measurements_path, method: :delete, class: "mt-4 space-y-3" do %>
                <label class="block text-xs font-medium text-slate-600"><%= t("measurements.type_delete_label") %></label>
                <input type="text" autocomplete="off" data-type-to-confirm-target="input" data-action="input->type-to-confirm#check"
                       class="w-full rounded-lg border border-slate-300 px-3 py-2 font-mono text-sm focus:border-rose-500 focus:ring-rose-500" placeholder="DELETE">
                <div class="flex justify-end gap-2 pt-1">
                  <button type="button" data-action="modal#close" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50"><%= t("habits.cancel") %></button>
                  <%= submit_tag t("measurements.clear_exams_do"), data: { type_to_confirm_target: "button" },
                        class: "rounded-lg bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-700 disabled:cursor-not-allowed disabled:opacity-40" %>
                </div>
              <% end %>
            </div>
          </dialog>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
