<%# locals: item ({type:, latest:, rows:, chart:}) — card de um tipo de exame. %>
<% latest = item[:latest] %>
<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="mb-3">
    <h3 class="font-semibold text-slate-900"><%= item[:type].name %></h3>
    <% if item[:type].description.present? %>
      <p class="text-xs text-slate-400"><%= item[:type].description %></p>
    <% end %>
    <p class="mt-0.5 text-2xl font-bold text-slate-900">
      <%= number_with_delimiter(latest.display_value) %>
      <span class="text-base font-medium text-slate-400"><%= latest.unit %></span>
      <% if latest.reference? %>
        <% if latest.out_of_range? %>
          <span class="ml-1 rounded-full bg-rose-100 px-2 py-0.5 text-xs font-semibold text-rose-700"><%= t("measurements.out_of_range") %></span>
        <% else %>
          <span class="ml-1 rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700"><%= t("measurements.in_range") %></span>
        <% end %>
      <% end %>
    </p>
    <% if latest.reference? %>
      <p class="text-xs text-slate-400"><%= t("measurements.reference", low: latest.ref_low&.to_f || "—", high: latest.ref_high&.to_f || "—", unit: latest.unit) %></p>
    <% end %>
    <p class="text-xs text-slate-400"><%= l(latest.measured_on, format: :long) %></p>
  </div>

  <% if item[:chart].any? %>
    <%= render "chart", chart: item[:chart], unit: latest.unit %>
  <% end %>

  <details class="mt-3">
    <summary class="cursor-pointer text-xs font-medium text-slate-500 hover:text-slate-700"><%= t("measurements.history") %> (<%= item[:rows].size %>)</summary>
    <ul class="mt-2 divide-y divide-slate-100">
      <% item[:rows].each do |r| %>
        <li class="flex items-center gap-3 py-1.5 text-sm">
          <span class="w-28 shrink-0 text-slate-500"><%= l(r.measured_on, format: :long) %></span>
          <span class="font-medium text-slate-900 <%= "text-rose-600" if r.out_of_range? %>"><%= number_with_delimiter(r.display_value) %> <%= r.unit %></span>
          <%= button_to t("memberships.remove"), exam_result_path(r), method: :delete,
                class: "ml-auto shrink-0 text-xs text-rose-600 hover:underline",
                form: { data: { turbo_confirm: t("measurements.remove_confirm") } } %>
        </li>
      <% end %>
    </ul>
  </details>
</section>
