<%# locals: g (grupo de métrica), category (String) %>
<% latest = g[:latest] %>
<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="mb-3 flex items-start justify-between gap-2">
    <div>
      <h3 class="flex items-center gap-1.5 font-semibold text-slate-900">
        <% if (ic = metric_icon(g[:key], css: "h-4 w-4 text-emerald-600")) %><%= ic %><% end %>
        <%= g[:label] %>
      </h3>
      <p class="mt-0.5 text-2xl font-bold text-slate-900">
        <%= latest.self_explanatory? ? latest.display_value : number_with_delimiter(latest.value) %>
        <% unless latest.self_explanatory? %><span class="text-base font-medium text-slate-400"><%= g[:unit] %></span><% end %>
        <% if latest.out_of_range? %>
          <span class="ml-1 rounded-full bg-rose-100 px-2 py-0.5 text-xs font-semibold text-rose-700"><%= t("measurements.out_of_range") %></span>
        <% elsif category == "exam" && (latest.ref_low.present? || latest.ref_high.present?) %>
          <span class="ml-1 rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700"><%= t("measurements.in_range") %></span>
        <% end %>
      </p>
      <% if category == "exam" && (latest.ref_low.present? || latest.ref_high.present?) %>
        <p class="text-xs text-slate-400"><%= t("measurements.reference", low: latest.ref_low&.to_s || "—", high: latest.ref_high&.to_s || "—", unit: g[:unit]) %></p>
      <% end %>
      <p class="text-xs text-slate-400"><%= l(latest.measured_on, format: :long) %></p>
    </div>
  </div>

  <% if g[:rows].any? %>
    <%= render "shared/line_chart", points: g[:rows].reverse.map { |m| { date: m.measured_on, value: m.value } }, unit: g[:unit] %>
  <% end %>

  <details class="mt-3">
    <summary class="cursor-pointer text-xs font-medium text-slate-500 hover:text-slate-700"><%= t("measurements.history") %> (<%= g[:rows].size %>)</summary>
    <ul class="mt-2 divide-y divide-slate-100">
      <% g[:rows].each do |m| %>
        <li class="flex items-center gap-3 py-1.5 text-sm">
          <span class="w-28 shrink-0 text-slate-500"><%= l(m.measured_on, format: :long) %></span>
          <span class="font-medium text-slate-900 <%= "text-rose-600" if m.out_of_range? %>"><%= m.self_explanatory? ? m.display_value : "#{number_with_delimiter(m.value)} #{m.unit}" %></span>
          <%= button_to t("memberships.remove"), measurement_path(m), method: :delete,
                class: "ml-auto shrink-0 text-xs text-rose-600 hover:underline",
                form: { data: { turbo_confirm: t("measurements.remove_confirm") } } %>
        </li>
      <% end %>
    </ul>
  </details>
</section>
