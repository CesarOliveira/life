<div class="space-y-4">
  <div class="flex items-end justify-between">
    <h1 class="text-2xl font-bold text-slate-900"><%= t("admin.ingestion.title") %></h1>
    <p class="text-sm text-slate-500"><%= t("admin.ingestion.count", count: @count) %></p>
  </div>
  <p class="text-sm text-slate-500"><%= t("admin.ingestion.hint") %></p>

  <% if @logs.empty? %>
    <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-500 shadow-sm"><%= t("admin.ingestion.empty") %></div>
  <% else %>
    <div class="space-y-2">
      <% @logs.each do |log| %>
        <details class="rounded-xl border border-slate-200 bg-white p-3 shadow-sm">
          <summary class="flex cursor-pointer flex-wrap items-center gap-2 text-sm">
            <span class="rounded-full px-2 py-0.5 text-xs font-semibold <%= log.ok? ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>"><%= log.status %></span>
            <span class="font-mono text-xs font-semibold text-slate-700"><%= log.endpoint %></span>
            <% if log.query["key"].present? %><span class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-600"><%= log.query["key"] %></span><% end %>
            <% if log.query["period"].present? %><span class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-600">period=<%= log.query["period"] %></span><% end %>
            <span class="text-xs text-slate-500"><%= log.client_version %></span>
            <span class="ml-auto text-xs text-slate-400"><%= l(log.created_at, format: :short) %> · <%= number_to_human_size(log.byte_size) %></span>
          </summary>
          <div class="mt-3 space-y-2 text-xs">
            <div class="flex flex-wrap gap-3 text-slate-500">
              <span><%= t("admin.ingestion.account") %>: <%= log.account&.name || "—" %></span>
              <span>IP: <%= log.ip %></span>
              <span><%= t("admin.ingestion.result") %>: <code class="text-slate-700"><%= log.result.to_json %></code></span>
            </div>
            <div>
              <p class="mb-1 font-medium text-slate-600"><%= t("admin.ingestion.raw_body") %></p>
              <pre class="max-h-64 overflow-auto whitespace-pre-wrap rounded-lg bg-slate-900 p-3 text-[11px] leading-snug text-slate-100"><%= log.raw_body.presence || "—" %></pre>
            </div>
          </div>
        </details>
      <% end %>
    </div>
  <% end %>
</div>
