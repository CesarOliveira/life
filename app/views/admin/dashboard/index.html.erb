<h1 class="text-2xl font-bold mb-6">Painel administrativo</h1>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded shadow p-4">
    <div class="text-3xl font-bold text-amber-600"><%= @pending_memberships.size %></div>
    <div class="text-sm text-gray-500">Aprovações pendentes</div>
  </div>
  <div class="bg-white rounded shadow p-4">
    <div class="text-3xl font-bold"><%= @users_count %></div>
    <div class="text-sm text-gray-500">Usuários</div>
  </div>
  <div class="bg-white rounded shadow p-4">
    <div class="text-3xl font-bold"><%= @accounts_count %></div>
    <div class="text-sm text-gray-500">Contas</div>
  </div>
  <div class="bg-white rounded shadow p-4">
    <div class="text-3xl font-bold text-green-600"><%= @active_count %></div>
    <div class="text-sm text-gray-500">Vínculos ativos</div>
  </div>
</div>

<h2 class="text-lg font-semibold mb-3">Aprovações pendentes</h2>
<% if @pending_memberships.empty? %>
  <p class="text-gray-500">Nada pendente. ✅</p>
<% else %>
  <div class="bg-white rounded shadow overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-left">
        <tr>
          <th class="px-4 py-2">Usuário</th>
          <th class="px-4 py-2">Conta</th>
          <th class="px-4 py-2">Papel</th>
          <th class="px-4 py-2">Quando</th>
          <th class="px-4 py-2 text-right">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @pending_memberships.each do |m| %>
          <tr>
            <td class="px-4 py-2">
              <div class="font-medium"><%= m.user.name %></div>
              <div class="text-gray-500"><%= m.user.email %></div>
            </td>
            <td class="px-4 py-2"><%= m.account.name %></td>
            <td class="px-4 py-2"><%= m.role %></td>
            <td class="px-4 py-2 text-gray-500"><%= m.created_at.strftime("%d/%m/%Y %H:%M") %></td>
            <td class="px-4 py-2 text-right space-x-2 whitespace-nowrap">
              <%= button_to "Aprovar", admin_membership_path(m), method: :patch,
                    class: "bg-green-600 text-white px-3 py-1 rounded text-xs font-semibold hover:bg-green-700 cursor-pointer" %>
              <%= button_to "Recusar", admin_membership_path(m), method: :delete,
                    form: { data: { turbo_confirm: "Recusar e remover #{m.user.email}?" } },
                    class: "bg-red-100 text-red-700 px-3 py-1 rounded text-xs font-semibold hover:bg-red-200 cursor-pointer" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
