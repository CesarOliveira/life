<h1 class="mb-6 text-2xl font-bold text-slate-900"><%= t("admin.dashboard.title") %></h1>

<div class="mb-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-3xl font-bold text-amber-600"><%= @pending_memberships.size %></div>
    <div class="text-sm text-slate-500"><%= t("admin.dashboard.pending_approvals") %></div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-3xl font-bold text-slate-900"><%= @users_count %></div>
    <div class="text-sm text-slate-500"><%= t("admin.dashboard.users") %></div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-3xl font-bold text-slate-900"><%= @accounts_count %></div>
    <div class="text-sm text-slate-500"><%= t("admin.dashboard.accounts") %></div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-3xl font-bold text-emerald-600"><%= @active_count %></div>
    <div class="text-sm text-slate-500"><%= t("admin.dashboard.active_memberships") %></div>
  </div>
</div>

<h2 class="mb-3 text-lg font-semibold text-slate-900"><%= t("admin.dashboard.pending_approvals") %></h2>
<% if @pending_memberships.empty? %>
  <p class="text-slate-500"><%= t("admin.dashboard.nothing_pending") %></p>
<% else %>
  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-left text-slate-500">
        <tr>
          <th class="px-4 py-2"><%= t("admin.dashboard.col_user") %></th>
          <th class="px-4 py-2"><%= t("admin.dashboard.col_account") %></th>
          <th class="px-4 py-2"><%= t("admin.dashboard.col_role") %></th>
          <th class="px-4 py-2"><%= t("admin.dashboard.col_when") %></th>
          <th class="px-4 py-2 text-right"><%= t("admin.dashboard.col_actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @pending_memberships.each do |m| %>
          <tr>
            <td class="px-4 py-2">
              <div class="font-medium text-slate-900"><%= m.user.name %></div>
              <div class="text-slate-500"><%= m.user.email %></div>
            </td>
            <td class="px-4 py-2"><%= m.account.name %></td>
            <td class="px-4 py-2"><%= m.role %></td>
            <td class="px-4 py-2 text-slate-500"><%= l(m.created_at, format: :long) %></td>
            <td class="space-x-2 whitespace-nowrap px-4 py-2 text-right">
              <%= button_to t("admin.dashboard.approve"), admin_membership_path(m), method: :patch,
                    class: "rounded bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700" %>
              <%= button_to t("admin.dashboard.reject"), admin_membership_path(m), method: :delete,
                    form: { data: { turbo_confirm: t("admin.dashboard.reject_confirm", email: m.user.email) } },
                    class: "rounded bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700 hover:bg-rose-200" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
