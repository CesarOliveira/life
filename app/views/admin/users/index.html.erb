<h1 class="mb-6 text-2xl font-bold text-slate-900"><%= t("admin.users.title") %></h1>
<p class="mb-4 text-sm text-slate-500"><%= t("admin.users.hint") %></p>

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-left text-slate-500">
      <tr>
        <th class="px-4 py-2"><%= t("admin.users.col_name") %></th>
        <th class="px-4 py-2"><%= t("admin.users.col_email") %></th>
        <th class="px-4 py-2"><%= t("admin.users.col_login") %></th>
        <th class="px-4 py-2"><%= t("admin.users.col_accounts") %></th>
        <th class="px-4 py-2"><%= t("admin.users.col_roles") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @users.each do |u| %>
        <tr>
          <td class="px-4 py-2 font-medium text-slate-900"><%= u.name %></td>
          <td class="px-4 py-2"><%= u.email %></td>
          <td class="px-4 py-2"><%= u.provider == "google_oauth2" ? t("admin.users.login_google") : t("admin.users.login_password") %></td>
          <td class="space-x-1 px-4 py-2">
            <% u.memberships.each do |m| %>
              <span class="inline-block rounded px-2 py-0.5 text-xs <%= m.active? ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700" %>">
                <%= m.account.name %>: <%= t("memberships.statuses.#{m.status}", default: m.status) %>
              </span>
            <% end %>
          </td>
          <td class="px-4 py-2">
            <div class="flex flex-wrap items-center gap-1">
              <% Role::KNOWN.each do |role| %>
                <% has = u.role?(role) %>
                <%= button_to admin_user_path(u, role: role, grant: has ? "0" : "1"), method: :patch,
                      class: "rounded px-2 py-0.5 text-xs font-medium #{has ? "bg-emerald-600 text-white hover:bg-emerald-700" : "bg-slate-100 text-slate-500 hover:bg-slate-200"}" do %>
                  <%= has ? "✓ #{t("roles.#{role}", default: role)}" : t("roles.#{role}", default: role) %>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
