<h1 class="text-2xl font-bold mb-6">Usuários</h1>

<p class="text-sm text-gray-500 mb-4">Clique numa role para conceder ou remover.</p>

<div class="bg-white rounded shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-gray-500 text-left">
      <tr>
        <th class="px-4 py-2">Nome</th>
        <th class="px-4 py-2">E-mail</th>
        <th class="px-4 py-2">Login</th>
        <th class="px-4 py-2">Contas</th>
        <th class="px-4 py-2">Roles</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @users.each do |u| %>
        <tr>
          <td class="px-4 py-2 font-medium"><%= u.name %></td>
          <td class="px-4 py-2"><%= u.email %></td>
          <td class="px-4 py-2"><%= u.provider == "google_oauth2" ? "Google" : "E-mail/senha" %></td>
          <td class="px-4 py-2 space-x-1">
            <% u.memberships.each do |m| %>
              <span class="inline-block px-2 py-0.5 rounded text-xs <%= m.active? ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>">
                <%= m.account.name %>: <%= m.status %>
              </span>
            <% end %>
          </td>
          <td class="px-4 py-2">
            <div class="flex flex-wrap items-center gap-1">
              <% Role::KNOWN.each do |role| %>
                <% has = u.role?(role) %>
                <%= button_to admin_user_path(u, role: role, grant: has ? "0" : "1"), method: :patch,
                      class: "px-2 py-0.5 rounded text-xs font-medium cursor-pointer #{has ? 'bg-indigo-600 text-white hover:bg-indigo-700' : 'bg-gray-100 text-gray-500 hover:bg-gray-200'}" do %>
                  <%= has ? "✓ #{role}" : role %>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
