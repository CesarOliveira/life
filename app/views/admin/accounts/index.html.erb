<h1 class="mb-6 text-2xl font-bold text-slate-900"><%= t("admin.accounts.title") %></h1>

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-left text-slate-500">
      <tr>
        <th class="px-4 py-2"><%= t("admin.accounts.col_account") %></th>
        <th class="px-4 py-2"><%= t("admin.accounts.col_owner") %></th>
        <th class="px-4 py-2"><%= t("admin.accounts.col_members") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @accounts.each do |a| %>
        <tr>
          <td class="px-4 py-2 font-medium text-slate-900"><%= a.name %></td>
          <td class="px-4 py-2"><%= a.owner&.email %></td>
          <td class="px-4 py-2"><%= t("admin.accounts.members_count", total: a.memberships.size, active: a.memberships.select(&:active?).size) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
