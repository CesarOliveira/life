<div class="mx-auto max-w-md">
  <h1 class="mb-6 text-2xl font-bold text-slate-900"><%= t("accounts.new_title") %></h1>

  <%= form_with model: @account, url: accounts_path, method: :post, class: "space-y-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |f| %>
    <% if @account.errors.any? %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 p-2 text-sm text-rose-700">
        <%= @account.errors.full_messages.to_sentence %>
      </div>
    <% end %>
    <div>
      <%= f.label :locale, t("accounts.locale_label"), class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.select :locale,
            options_for_select(Account::LOCALES.map { |l| [t("accounts.locales.#{l}"), l] }, @account.locale || I18n.locale.to_s),
            {},
            class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      <p class="mt-1 text-xs text-slate-500"><%= t("accounts.locale_hint") %></p>
    </div>

    <div>
      <%= f.label :name, Account.human_attribute_name(:name), class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
    </div>
    <div class="flex items-center gap-3">
      <%= f.submit t("accounts.create"), class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
      <%= link_to t("accounts.cancel"), authenticated_root_path, class: "text-sm text-slate-500 hover:underline" %>
    </div>
  <% end %>
</div>
