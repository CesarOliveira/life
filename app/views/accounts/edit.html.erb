<div class="mx-auto max-w-md">
  <h1 class="mb-6 text-2xl font-bold text-slate-900"><%= t("accounts.settings_title") %></h1>

  <%= form_with model: @account, url: account_path(@account), method: :patch, class: "space-y-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |f| %>
    <% if @account.errors.any? %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 p-2 text-sm text-rose-700">
        <%= @account.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, Account.human_attribute_name(:name), class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
    </div>

    <div>
      <%= f.label :height_cm, Account.human_attribute_name(:height_cm), class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= f.number_field :height_cm, min: 0, max: 300, class: "w-32 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      <p class="mt-1 text-xs text-slate-500"><%= t("weights.no_height") %></p>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit t("accounts.save"), class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
      <%= link_to t("accounts.cancel"), authenticated_root_path, class: "text-sm text-slate-500 hover:underline" %>
    </div>
  <% end %>

  <%# Categorias de hábitos (até 10) — alimentam o radar da Atividade %>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-1 text-sm font-medium text-slate-700"><%= t("categories.title") %></h2>
    <p class="mb-4 text-xs text-slate-500"><%= t("categories.hint", max: HabitCategory::MAX_PER_ACCOUNT) %></p>

    <ul class="space-y-2">
      <% current_account.habit_categories.ordered.each do |cat| %>
        <li class="flex items-center gap-2">
          <%= form_with model: cat, url: habit_category_path(cat), method: :patch, class: "flex flex-1 items-center gap-2" do |f| %>
            <%= f.text_field :name, class: "flex-1 rounded-lg border border-slate-300 px-3 py-1.5 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
            <%= f.submit t("categories.rename"), class: "cursor-pointer rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50" %>
          <% end %>
          <%= button_to "✕", habit_category_path(cat), method: :delete,
                class: "cursor-pointer rounded-lg border border-slate-200 px-2.5 py-1.5 text-xs text-rose-500 hover:bg-rose-50",
                form: { data: { turbo_confirm: t("categories.remove_confirm", name: cat.name) } } %>
        </li>
      <% end %>
    </ul>

    <% if current_account.habit_categories.count < HabitCategory::MAX_PER_ACCOUNT %>
      <%= form_with model: HabitCategory.new, url: habit_categories_path, method: :post, class: "mt-3 flex items-center gap-2 border-t border-slate-100 pt-3" do |f| %>
        <%= f.text_field :name, placeholder: t("categories.new_placeholder"), required: true,
              class: "flex-1 rounded-lg border border-slate-300 px-3 py-1.5 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
        <%= f.submit t("categories.add"), class: "cursor-pointer rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-700" %>
      <% end %>
    <% end %>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-1 text-sm font-medium text-slate-700"><%= t("accounts.language") %></h2>
    <p class="mb-3 text-xs text-slate-500"><%= t("accounts.language_hint") %></p>
    <div class="inline-flex items-center overflow-hidden rounded-lg border border-slate-200 text-sm">
      <% I18n.available_locales.each do |loc| %>
        <%= link_to locale_label(loc), locale_switch_path(loc),
              class: "px-3 py-1.5 #{I18n.locale == loc ? "bg-emerald-50 font-semibold text-emerald-700" : "text-slate-500 hover:bg-slate-50"}" %>
      <% end %>
    </div>
  </div>
</div>
