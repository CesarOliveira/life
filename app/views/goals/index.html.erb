<div class="space-y-6">
  <h1 class="text-2xl font-bold text-slate-900"><%= t("goals.title") %></h1>

  <%# Nova meta %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="mb-3 font-semibold text-slate-900"><%= t("goals.add") %></h2>
    <%= form_with model: @goal, url: goals_path, method: :post, class: "flex flex-wrap items-end gap-3" do |f| %>
      <% if @goal.errors.any? %>
        <div class="w-full rounded-lg border border-rose-200 bg-rose-50 p-2 text-sm text-rose-700">
          <%= @goal.errors.full_messages.to_sentence %>
        </div>
      <% end %>
      <div>
        <%= f.label :name, t("goals.name"), class: "mb-1 block text-xs font-medium text-slate-600" %>
        <%= f.text_field :name, required: true, placeholder: t("goals.name_placeholder"),
              class: "rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div>
        <%= f.label :metric_key, t("goals.metric"), class: "mb-1 block text-xs font-medium text-slate-600" %>
        <%= f.select :metric_key,
              options_for_select(@metric_keys.map { |k| [goal_metric_label(k), k] }, @goal.metric_key),
              {},
              class: "rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div>
        <%= f.label :target_value, t("goals.target"), class: "mb-1 block text-xs font-medium text-slate-600" %>
        <%= f.number_field :target_value, step: "any", required: true,
              class: "w-24 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div>
        <%= f.label :start_value, t("goals.start"), class: "mb-1 block text-xs font-medium text-slate-600" %>
        <%= f.number_field :start_value, step: "any", placeholder: t("goals.start_auto"),
              class: "w-24 rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div>
        <%= f.label :deadline, t("goals.deadline"), class: "mb-1 block text-xs font-medium text-slate-600" %>
        <%= f.date_field :deadline,
              class: "rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <%= f.submit t("goals.add"), class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
    <% end %>
  </section>

  <% if @goals.empty? %>
    <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center text-slate-500 shadow-sm">
      <%= t("goals.empty") %>
    </div>
  <% else %>
    <div class="grid gap-4 sm:grid-cols-2">
      <% @goals.each do |goal| %>
        <% p = @progress[goal] %>
        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="mb-2 flex items-start justify-between gap-2">
            <div class="min-w-0">
              <h3 class="truncate font-semibold text-slate-900"><%= goal.name %></h3>
              <p class="text-xs text-slate-400"><%= goal.metric_label %></p>
            </div>
            <% if p.achieved? %>
              <span class="shrink-0 rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700">
                <%= p.achieved_on ? t("goals.achieved_on", date: l(p.achieved_on, format: :long)) : t("goals.achieved") %>
              </span>
            <% end %>
          </div>

          <% if p.data? %>
            <div class="mb-1 flex items-end justify-between text-sm">
              <span class="text-2xl font-bold text-slate-900"><%= number_with_delimiter(p.current_value) %> <span class="text-base font-medium text-slate-400"><%= goal.unit %></span></span>
              <span class="text-slate-400"><%= t("goals.target_label") %> <span class="font-semibold text-slate-700"><%= number_with_delimiter(p.target_value) %> <%= goal.unit %></span></span>
            </div>
            <div class="h-2.5 w-full overflow-hidden rounded-full bg-slate-100">
              <div class="h-full rounded-full <%= p.achieved? ? "bg-emerald-500" : "bg-emerald-400" %>" style="width: <%= p.progress_pct %>%"></div>
            </div>
            <div class="mt-1 flex items-center justify-between text-xs text-slate-400">
              <span><%= t("goals.start_label") %> <%= number_with_delimiter(p.start_value) %> <%= goal.unit %></span>
              <span><%= p.progress_pct %>%</span>
            </div>
            <% unless p.achieved? %>
              <p class="mt-2 text-xs text-slate-500"><%= t("goals.remaining", value: number_with_delimiter(p.remaining), unit: goal.unit) %></p>
            <% end %>
          <% else %>
            <p class="text-sm text-slate-500"><%= t("goals.no_data") %></p>
          <% end %>

          <% if goal.deadline %>
            <p class="mt-2 text-xs text-slate-400"><%= t("goals.deadline_label", date: l(goal.deadline, format: :long)) %></p>
          <% end %>

          <div class="mt-3 text-right">
            <%= button_to t("memberships.remove"), goal_path(goal), method: :delete,
                  class: "text-xs text-rose-600 hover:underline",
                  form: { data: { turbo_confirm: t("goals.remove_confirm") } } %>
          </div>
        </section>
      <% end %>
    </div>
  <% end %>
</div>
