<div class="flex min-h-screen items-center justify-center bg-slate-50 px-4">
  <div class="w-full max-w-md">
    <div class="mb-3 flex justify-end">
      <div class="flex items-center overflow-hidden rounded-lg border border-slate-200 bg-white text-xs">
        <% I18n.available_locales.each do |loc| %>
          <%= link_to locale_label(loc), locale_switch_path(loc),
                class: "px-2 py-1 #{I18n.locale == loc ? "bg-emerald-50 font-semibold text-emerald-700" : "text-slate-500 hover:bg-slate-50"}" %>
        <% end %>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <div class="mb-6 text-center">
        <span class="mx-auto mb-2 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-500 text-white">✦</span>
        <h1 class="text-2xl font-bold text-slate-900">Life</h1>
        <p class="mt-1 text-sm text-slate-500"><%= t("auth.tagline") %></p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, t("auth.email"), class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
          </div>

          <div>
            <%= f.label :password, t("auth.password"), class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.password_field :password, autocomplete: "current-password",
                  class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
          </div>

          <label class="flex items-center gap-2 text-sm text-slate-600">
            <%= f.check_box :remember_me, class: "accent-emerald-600" %>
            <%= t("auth.remember_me") %>
          </label>

          <%= f.submit t("auth.sign_in"), class: "w-full cursor-pointer rounded-lg bg-emerald-600 py-2 font-semibold text-white hover:bg-emerald-700" %>
        </div>
      <% end %>

      <% if ENV["GOOGLE_CLIENT_ID"].present? %>
        <div class="relative mt-6">
          <div class="absolute inset-0 flex items-center" aria-hidden="true">
            <div class="w-full border-t border-slate-200"></div>
          </div>
          <div class="relative flex justify-center text-xs">
            <span class="bg-white px-2 text-slate-400"><%= t("auth.or") %></span>
          </div>
        </div>

        <%# data-turbo=false: o submit redireciona para o Google (domínio externo). %>
        <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false },
              class: "mt-4 flex w-full cursor-pointer items-center justify-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" do %>
          <svg class="h-4 w-4" viewBox="0 0 48 48" aria-hidden="true">
            <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3c-1.6 4.7-6.1 8-11.3 8-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.3-.4-3.5z"/>
            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 18.9 13 24 13c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34 6.1 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
            <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2C29.2 35 26.7 36 24 36c-5.2 0-9.6-3.3-11.3-7.9l-6.5 5C9.6 39.6 16.2 44 24 44z"/>
            <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.2-2.2 4.1-4.1 5.6l6.2 5.2C39.9 36.1 44 30.6 44 24c0-1.3-.1-2.3-.4-3.5z"/>
          </svg>
          <span><%= t("auth.sign_in_google") %></span>
        <% end %>
      <% end %>

      <div class="mt-4 text-center text-sm text-slate-500">
        <%= link_to t("auth.forgot_password"), new_password_path(resource_name), class: "text-emerald-600 hover:underline" %>
        &nbsp;·&nbsp;
        <%= link_to t("auth.sign_up"), new_registration_path(resource_name), class: "text-emerald-600 hover:underline" %>
      </div>
    </div>
  </div>
</div>
