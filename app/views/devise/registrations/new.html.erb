<div class="flex min-h-screen items-center justify-center bg-slate-50 px-4">
  <div class="w-full max-w-md">
    <div class="mb-3 flex justify-end">
      <div class="flex items-center overflow-hidden rounded-lg border border-slate-200 bg-white text-xs">
        <% I18n.available_locales.each do |loc| %>
          <%= link_to locale_label(loc), locale_switch_path(loc),
                class: "px-2 py-1 #{I18n.locale == loc ? "bg-emerald-50 font-semibold text-emerald-700" : "text-slate-500 hover:bg-slate-50"}" %>
        <% end %>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <div class="mb-6 text-center">
        <span class="mx-auto mb-2 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-500 text-white">✦</span>
        <h1 class="text-2xl font-bold text-slate-900"><%= t("auth.sign_up_title") %></h1>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <% if resource.errors.any? %>
          <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 p-3">
            <% resource.errors.full_messages.each do |msg| %>
              <p class="text-sm text-rose-700"><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div class="space-y-4">
          <div>
            <%= f.label :name, t("auth.name"), class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.text_field :name, autofocus: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
          </div>
          <div>
            <%= f.label :email, t("auth.email"), class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
          </div>
          <div>
            <%= f.label :password, t("auth.password_min"), class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
          </div>
          <div>
            <%= f.label :password_confirmation, t("auth.password_confirmation"), class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
          </div>
          <%= f.submit t("auth.sign_up"), class: "w-full cursor-pointer rounded-lg bg-emerald-600 py-2 font-semibold text-white hover:bg-emerald-700" %>
        </div>
      <% end %>

      <div class="mt-4 text-center text-sm text-slate-500">
        <%= t("auth.have_account") %>
        <%= link_to t("auth.sign_in"), new_session_path(resource_name), class: "text-emerald-600 hover:underline" %>
      </div>
    </div>
  </div>
</div>
