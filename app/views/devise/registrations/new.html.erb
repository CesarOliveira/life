<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="max-w-md w-full bg-white rounded-lg shadow p-8">
    <h1 class="text-2xl font-bold text-indigo-700 text-center mb-6">Criar Conta</h1>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <% if resource.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded p-3 mb-4">
          <% resource.errors.full_messages.each do |msg| %>
            <p class="text-sm text-red-600"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, autofocus: true, class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :password, "Senha (mín. 6 caracteres)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>

        <%= f.submit "Criar conta", class: "w-full bg-indigo-600 text-white py-2 rounded hover:bg-indigo-700 cursor-pointer font-semibold" %>
      </div>
    <% end %>

    <div class="mt-4 text-center text-sm text-gray-500">
      <%= link_to "Já tenho conta", new_session_path(resource_name), class: "text-indigo-600 hover:underline" %>
    </div>
  </div>
</div>
