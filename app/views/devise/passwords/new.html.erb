<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="max-w-md w-full bg-white rounded-lg shadow p-8">
    <h1 class="text-xl font-bold text-center mb-6">Recuperar Senha</h1>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
        <%= f.submit "Enviar instruções", class: "w-full bg-indigo-600 text-white py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-4 text-center">
      <%= link_to "Voltar ao login", new_session_path(resource_name), class: "text-sm text-indigo-600 hover:underline" %>
    </div>
  </div>
</div>
