<h1 class="mb-6 text-2xl font-bold text-slate-900"><%= t("habits.edit_title") %></h1>
<%= render "form", submit_label: t("habits.update_submit") %>

<div class="mt-4 max-w-lg">
  <%= button_to t("habits.remove"), habit_path(@habit), method: :delete,
        class: "text-sm text-rose-600 hover:underline",
        form: { data: { turbo_confirm: t("habits.remove_confirm") } } %>
</div>
