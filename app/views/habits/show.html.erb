<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <span class="h-4 w-4 shrink-0 rounded-full" style="background-color: <%= @habit.color %>"></span>
      <div class="min-w-0">
        <h1 class="truncate text-2xl font-bold text-slate-900"><%= @habit.name %></h1>
        <p class="text-sm text-slate-500"><%= cadence_label(@habit) %></p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to t("habits.edit"), edit_habit_path(@habit),
            class: "rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-50" %>
      <%= link_to t("habits.back_to_list"), habits_path, class: "text-sm text-slate-500 hover:underline" %>
    </div>
  </div>

  <% if @habit.description.present? %>
    <p class="text-sm text-slate-600"><%= @habit.description %></p>
  <% end %>

  <%# Resumo: força, sequência, adesão, semana %>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-xs text-slate-500"><%= t("habits.strength_label") %></p>
      <p class="mt-1">
        <span class="rounded-full px-2 py-0.5 text-sm font-medium <%= strength_badge_class(@stats.strength) %>"><%= strength_label(@stats.strength) %></span>
      </p>
      <p class="mt-1 text-xs text-slate-400"><%= @stats.strength_pct %>% · <%= t("habits.strength_window") %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-xs text-slate-500"><%= t("habits.streak_tooltip") %></p>
      <p class="mt-1 text-2xl font-bold text-slate-900">🔥 <%= @stats.current_streak %></p>
      <p class="text-xs text-slate-400"><%= @habit.weekly_count? ? t("habits.weeks") : t("habits.days") %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-xs text-slate-500"><%= t("habits.adherence_tooltip") %></p>
      <p class="mt-1 text-2xl font-bold text-slate-900"><%= @stats.adherence %>%</p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-xs text-slate-500"><%= t("habits.this_week") %></p>
      <p class="mt-1 text-2xl font-bold text-slate-900"><%= @stats.done_this_week %><span class="text-base font-normal text-slate-400">/<%= @stats.week_target %></span></p>
    </div>
  </div>

  <%# Heatmap do hábito (últimos 3 meses) %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="mb-4 font-semibold text-slate-900"><%= t("habits.history") %></h2>
    <%= render "shared/contributions", graph: @graph %>
  </section>

  <%# Timeline detalhada: feito / perdido / não agendado (últimos 28 dias) %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="mb-4 font-semibold text-slate-900"><%= t("habits.timeline_title") %></h2>
    <div class="flex flex-wrap gap-1.5">
      <% @timeline.each do |day| %>
        <% if !day[:scheduled] %>
          <span class="flex h-9 w-9 flex-col items-center justify-center rounded bg-slate-50 text-[10px] text-slate-300"
                title="<%= t("habits.not_scheduled", date: l(day[:date], format: :long)) %>">
            <span><%= day[:date].day %></span>
          </span>
        <% elsif day[:done] %>
          <span class="flex h-9 w-9 flex-col items-center justify-center rounded bg-emerald-500 text-[10px] font-medium text-white"
                title="<%= t("habits.done_on", date: l(day[:date], format: :long)) %>">
            <span><%= day[:date].day %></span>
          </span>
        <% else %>
          <span class="flex h-9 w-9 flex-col items-center justify-center rounded bg-slate-100 text-[10px] text-slate-400 ring-1 ring-inset ring-slate-300"
                title="<%= t("habits.missed_on", date: l(day[:date], format: :long)) %>">
            <span><%= day[:date].day %></span>
          </span>
        <% end %>
      <% end %>
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-[11px] text-slate-400">
      <span class="flex items-center gap-1"><span class="h-3 w-3 rounded-sm bg-emerald-500"></span><%= t("habits.legend_done") %></span>
      <span class="flex items-center gap-1"><span class="h-3 w-3 rounded-sm bg-slate-100 ring-1 ring-inset ring-slate-300"></span><%= t("habits.legend_missed") %></span>
      <span class="flex items-center gap-1"><span class="h-3 w-3 rounded-sm bg-slate-50"></span><%= t("habits.legend_idle") %></span>
    </div>
  </section>
</div>
