<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= t("habits.title") %></h1>
      <p class="text-sm text-slate-500"><%= l(@today, format: :long) %></p>
    </div>
    <%= link_to t("habits.new"), new_habit_path,
          class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
  </div>

  <% if @habits.empty? %>
    <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center shadow-sm">
      <p class="mb-4 text-slate-500"><%= t("habits.empty") %></p>
      <%= link_to t("habits.create_first"), new_habit_path,
            class: "inline-block rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
    </div>
  <% else %>
    <% today_habits = @habits.select { |h| @stats[h].scheduled_today? } %>
    <% done_today = today_habits.count { |h| @stats[h].done_today? } %>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-semibold text-slate-900"><%= t("habits.today") %></h2>
        <span class="text-sm text-slate-400"><%= t("habits.completed", done: done_today, total: today_habits.size) %></span>
      </div>

      <% if today_habits.empty? %>
        <p class="text-sm text-slate-500"><%= t("habits.none_today") %></p>
      <% else %>
        <ul class="divide-y divide-slate-100">
          <% today_habits.each do |h| %>
            <% s = @stats[h] %>
            <% done = s.done_today? %>
            <li class="flex items-center gap-3 py-2.5">
              <% if h.auto? %>
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border-2 #{done ? "border-emerald-500 bg-emerald-500 text-white" : "border-slate-200 text-transparent"}"
                      title="<%= t("habits.auto_badge_hint") %>">
                  <span class="text-xs leading-none">✓</span>
                </span>
              <% else %>
                <%= button_to toggle_habit_path(h), params: { date: @today.iso8601 },
                      class: "flex h-7 w-7 shrink-0 items-center justify-center rounded-full border-2 transition #{done ? "border-emerald-500 bg-emerald-500 text-white" : "border-slate-300 text-transparent hover:border-emerald-400"}",
                      aria: { label: h.name } do %>
                  <span class="text-xs leading-none">✓</span>
                <% end %>
              <% end %>
              <span class="h-3 w-3 shrink-0 rounded-full" style="background-color: <%= h.color %>"></span>
              <span class="text-sm <%= "text-slate-400 line-through" if done %>"><%= h.name %></span>
              <% if h.auto? %>
                <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-medium text-slate-500"><%= t("habits.auto_badge") %></span>
              <% elsif h.weekly_count? %>
                <span class="rounded-full px-2 py-0.5 text-xs <%= s.week_met? ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-500" %>">
                  <%= t("habits.weekly_progress", done: s.done_this_week, target: s.week_target) %>
                </span>
              <% end %>
              <span class="ml-auto shrink-0 text-xs text-slate-400">🔥 <%= s.current_streak %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>

    <div class="space-y-3">
      <% @habits.each do |h| %>
        <% s = @stats[h] %>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <div class="flex items-center gap-3">
            <span class="h-3 w-3 shrink-0 rounded-full" style="background-color: <%= h.color %>"></span>
            <div class="min-w-0">
              <%= link_to h.name, habit_path(h), class: "block truncate font-semibold text-slate-900 hover:text-emerald-700" %>
              <p class="flex items-center gap-2 text-xs text-slate-500">
                <span><%= cadence_label(h) %></span>
                <span class="rounded-full px-1.5 py-0.5 text-[10px] font-medium <%= strength_badge_class(s.strength) %>"><%= strength_label(s.strength) %></span>
              </p>
            </div>
            <div class="ml-auto flex shrink-0 items-center gap-4 text-sm">
              <span title="<%= t("habits.streak_tooltip") %>">🔥 <span class="font-semibold text-slate-900"><%= s.current_streak %></span></span>
              <span title="<%= t("habits.adherence_tooltip") %>"><span class="font-semibold text-slate-900"><%= s.adherence %></span><span class="text-slate-400">%</span></span>
              <%= link_to t("habits.edit"), edit_habit_path(h), class: "text-xs font-medium text-emerald-600 hover:text-emerald-700" %>
            </div>
          </div>

          <div class="mt-3 flex gap-1">
            <% s.last_days(7).each do |day| %>
              <% if !day[:scheduled] %>
                <span class="flex h-8 w-8 items-center justify-center rounded bg-slate-50 text-[11px] text-slate-300"
                      title="<%= t("habits.not_scheduled", date: l(day[:date], format: :long)) %>">–</span>
              <% elsif h.auto? %>
                <span class="flex h-8 w-8 items-center justify-center rounded text-[11px] #{day[:done] ? "bg-emerald-500 text-white" : "bg-slate-100 text-slate-400"}"
                      title="<%= l(day[:date], format: :long) %>"><%= day[:date].day %></span>
              <% else %>
                <%= button_to toggle_habit_path(h), params: { date: day[:date].iso8601 },
                      class: "flex h-8 w-8 items-center justify-center rounded text-[11px] #{day[:done] ? "bg-emerald-500 text-white" : "bg-slate-100 text-slate-400 hover:bg-slate-200"}",
                      title: l(day[:date], format: :long) do %>
                  <%= day[:date].day %>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
