<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= t("habits.title") %></h1>
      <p class="text-sm text-slate-500"><%= l(@today, format: :long) %></p>
    </div>
    <%= link_to t("habits.new"), new_habit_path,
          class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
  </div>

  <% if @habits.empty? %>
    <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center shadow-sm">
      <p class="mb-4 text-slate-500"><%= t("habits.empty") %></p>
      <%= link_to t("habits.create_first"), new_habit_path,
            class: "inline-block rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
    </div>
  <% else %>
    <% today_habits = @habits.select { |h| @stats[h].scheduled_today? } %>
    <% done_today = today_habits.count { |h| @stats[h].done_today? } %>

    <%# ===== Hoje ===== %>
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="mb-1 flex items-center justify-between">
        <h2 class="font-semibold text-slate-900"><%= t("habits.today") %></h2>
        <span class="text-sm font-medium <%= done_today == today_habits.size && today_habits.any? ? "text-emerald-600" : "text-slate-400" %>">
          <%= t("habits.completed", done: done_today, total: today_habits.size) %>
        </span>
      </div>
      <%# Barra de progresso do dia %>
      <% pct_today = today_habits.any? ? (done_today * 100 / today_habits.size) : 0 %>
      <div class="mb-4 h-1.5 w-full rounded-full bg-slate-100">
        <div class="h-1.5 rounded-full bg-emerald-500 transition-all" style="width: <%= pct_today %>%"></div>
      </div>

      <% if today_habits.empty? %>
        <p class="text-sm text-slate-500"><%= t("habits.none_today") %></p>
      <% else %>
        <ul class="divide-y divide-slate-100">
          <% today_habits.each do |h| %>
            <% s = @stats[h] %>
            <% done = s.done_today? %>
            <li class="flex items-center gap-3 py-2.5">
              <% check_classes = done ? "border-emerald-500 bg-emerald-500 text-white" : "border-slate-300 text-transparent" %>
              <% if h.auto? %>
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border-2 <%= check_classes %>"
                      title="<%= t("habits.auto_badge_hint") %>">
                  <span class="text-xs leading-none">✓</span>
                </span>
              <% else %>
                <%= button_to toggle_habit_path(h), params: { date: @today.iso8601 },
                      class: "flex h-7 w-7 shrink-0 cursor-pointer items-center justify-center rounded-full border-2 transition #{check_classes} #{done ? "" : "hover:border-emerald-400"}",
                      aria: { label: h.name } do %>
                  <span class="text-xs leading-none">✓</span>
                <% end %>
              <% end %>
              <span class="h-3 w-3 shrink-0 rounded-full" style="background-color: <%= h.color %>"></span>
              <div class="min-w-0">
                <span class="block truncate text-sm <%= "text-slate-400 line-through" if done %>"><%= h.name %></span>
                <span class="block text-[11px] text-slate-400"><%= cadence_label(h) %></span>
              </div>
              <% if h.auto? %>
                <span class="shrink-0 rounded-full bg-indigo-50 px-2 py-0.5 text-[10px] font-medium text-indigo-500" title="<%= t("habits.auto_badge_hint") %>"><%= t("habits.auto_badge") %></span>
              <% elsif h.weekly_count? %>
                <span class="shrink-0 rounded-full px-2 py-0.5 text-xs <%= s.week_met? ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-500" %>">
                  <%= t("habits.weekly_progress", done: s.done_this_week, target: s.week_target) %>
                </span>
              <% end %>
              <span class="ml-auto shrink-0 text-xs text-slate-400" title="<%= t("habits.streak_tooltip") %>">🔥 <%= s.current_streak %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>

    <%# ===== Cards por hábito (última semana) ===== %>
    <div class="space-y-3">
      <% @habits.each do |h| %>
        <% s = @stats[h] %>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <div class="flex items-start gap-3">
            <span class="mt-1.5 h-3 w-3 shrink-0 rounded-full" style="background-color: <%= h.color %>"></span>
            <div class="min-w-0">
              <%= link_to h.name, habit_path(h), class: "block truncate font-semibold text-slate-900 hover:text-emerald-700" %>
              <p class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
                <span><%= cadence_label(h) %></span>
                <% if h.habit_category %>
                  <span class="rounded-full bg-slate-100 px-1.5 py-0.5 text-[10px] font-medium text-slate-500"><%= h.habit_category.name %></span>
                <% end %>
                <span class="rounded-full px-1.5 py-0.5 text-[10px] font-medium <%= strength_badge_class(s.strength) %>"><%= strength_label(s.strength) %></span>
              </p>
            </div>
            <div class="ml-auto flex shrink-0 items-center gap-4">
              <div class="text-center" title="<%= t("habits.streak_tooltip") %>">
                <div class="text-sm font-semibold text-slate-900">🔥 <%= s.current_streak %></div>
                <div class="text-[10px] uppercase tracking-wide text-slate-400"><%= t("habits.streak_label") %></div>
              </div>
              <div class="text-center" title="<%= t("habits.adherence_tooltip") %>">
                <div class="text-sm font-semibold text-slate-900"><%= s.adherence %><span class="font-normal text-slate-400">%</span></div>
                <div class="text-[10px] uppercase tracking-wide text-slate-400"><%= t("habits.adherence_label") %></div>
              </div>
              <%= link_to t("habits.edit"), edit_habit_path(h), class: "text-xs font-medium text-emerald-600 hover:text-emerald-700" %>
            </div>
          </div>

          <%# Faixa da semana: inicial do dia + número, colorido por estado %>
          <div class="mt-3 flex gap-1.5">
            <% s.last_days(7).each do |day| %>
              <% is_today = day[:date] == @today %>
              <% cell =
                   if !day[:scheduled]
                     "bg-slate-50 text-slate-300"
                   elsif day[:done]
                     "bg-emerald-500 text-white"
                   elsif is_today
                     "border-2 border-dashed border-emerald-300 bg-white text-slate-500"
                   else
                     "bg-rose-50 text-rose-400"
                   end %>
              <div class="flex flex-col items-center gap-0.5">
                <span class="text-[9px] font-medium uppercase text-slate-400"><%= t("date.abbr_day_names")[day[:date].wday].first(3) %></span>
                <% title = day[:scheduled] ? l(day[:date], format: :long) : t("habits.not_scheduled", date: l(day[:date], format: :long)) %>
                <% if h.auto? || !day[:scheduled] %>
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg text-[11px] font-medium <%= cell %>" title="<%= title %>">
                    <%= day[:scheduled] ? day[:date].day : "–" %>
                  </span>
                <% else %>
                  <%= button_to toggle_habit_path(h), params: { date: day[:date].iso8601 },
                        class: "flex h-8 w-8 cursor-pointer items-center justify-center rounded-lg text-[11px] font-medium transition hover:ring-2 hover:ring-emerald-300 #{cell}",
                        title: title do %>
                    <%= day[:date].day %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Legenda %>
    <div class="flex flex-wrap items-center gap-4 text-xs text-slate-500">
      <span class="flex items-center gap-1.5"><span class="h-3.5 w-3.5 rounded bg-emerald-500"></span> <%= t("habits.legend_done") %></span>
      <span class="flex items-center gap-1.5"><span class="h-3.5 w-3.5 rounded bg-rose-50 ring-1 ring-rose-200"></span> <%= t("habits.legend_missed") %></span>
      <span class="flex items-center gap-1.5"><span class="h-3.5 w-3.5 rounded border-2 border-dashed border-emerald-300 bg-white"></span> <%= t("habits.legend_today") %></span>
      <span class="flex items-center gap-1.5"><span class="h-3.5 w-3.5 rounded bg-slate-100"></span> <%= t("habits.legend_idle") %></span>
    </div>
  <% end %>
</div>
