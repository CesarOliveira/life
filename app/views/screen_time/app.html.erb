<div class="space-y-6">
  <div>
    <%= link_to "‹ #{t('screen_time.app_back')}", screen_time_path, class: "text-sm text-slate-500 hover:text-slate-900" %>
    <h1 class="mt-1 text-2xl font-bold text-slate-900"><%= @name %></h1>
    <p class="text-sm text-slate-500"><%= t("screen_time.app_period", days: 30) %></p>
  </div>

  <% if @daily.any? %>
    <div class="grid grid-cols-2 gap-3 sm:gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("screen_time.app_total") %></p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= humanize_duration(@total) %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("screen_time.app_days") %></p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= @days %></p>
      </div>
    </div>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="mb-4 font-semibold text-slate-900"><%= t("screen_time.app_daily") %></h2>
      <ul class="space-y-2">
        <% @daily.each do |d| %>
          <li class="flex items-center gap-3 text-sm">
            <span class="w-12 shrink-0 text-slate-500"><%= d[:date].strftime("%d/%m") %></span>
            <div class="h-3 flex-1 rounded-full bg-slate-100">
              <div class="h-3 rounded-full bg-emerald-500" style="width: <%= @max_day.zero? ? 0 : (d[:seconds] * 100 / @max_day) %>%"></div>
            </div>
            <span class="w-16 shrink-0 text-right font-medium text-slate-700"><%= humanize_duration(d[:seconds]) %></span>
          </li>
        <% end %>
      </ul>
    </section>
  <% else %>
    <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
      <p class="text-slate-500"><%= t("screen_time.app_empty") %></p>
    </div>
  <% end %>
</div>
