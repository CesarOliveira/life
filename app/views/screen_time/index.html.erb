<div class="space-y-6">
  <h1 class="text-2xl font-bold text-slate-900"><%= t("screen_time.title") %></h1>

  <% if @apps.any? %>
    <div class="grid grid-cols-2 gap-3 sm:gap-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("screen_time.today") %></p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= humanize_duration(@total_today) %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("screen_time.this_week") %></p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= humanize_duration(@total_week) %></p>
      </div>
    </div>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="mb-4 font-semibold text-slate-900"><%= t("screen_time.by_app") %></h2>
      <ul class="space-y-3">
        <% @apps.each do |a| %>
          <li>
            <div class="mb-1 flex items-center justify-between gap-3 text-sm">
              <span class="truncate font-medium text-slate-700"><%= a[:name] %></span>
              <span class="shrink-0 text-slate-500"><%= humanize_duration(a[:seconds]) %></span>
            </div>
            <div class="h-2 w-full rounded-full bg-slate-100">
              <div class="h-2 rounded-full bg-emerald-500" style="width: <%= @max_app.zero? ? 0 : (a[:seconds] * 100 / @max_app) %>%"></div>
            </div>
          </li>
        <% end %>
      </ul>
    </section>
  <% else %>
    <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
      <p class="text-slate-500"><%= t("screen_time.empty") %></p>
    </div>
  <% end %>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="mb-1 font-semibold text-slate-900"><%= t("screen_time.setup_title") %></h2>
    <p class="mb-4 text-sm text-slate-500"><%= t("screen_time.setup_intro") %></p>

    <div class="space-y-3">
      <div>
        <p class="mb-1 text-xs font-medium text-slate-600"><%= t("screen_time.endpoint_label") %></p>
        <code class="block break-all rounded-lg bg-slate-100 px-3 py-2 text-xs text-slate-700"><%= api_usage_url %></code>
      </div>
      <div>
        <p class="mb-1 text-xs font-medium text-slate-600"><%= t("screen_time.token_label") %></p>
        <code class="block break-all rounded-lg bg-slate-100 px-3 py-2 text-xs text-slate-700"><%= @token %></code>
        <p class="mt-1 text-xs text-amber-600"><%= t("screen_time.keep_secret") %></p>
      </div>
      <div class="flex items-center gap-3 pt-1">
        <%= button_to t("screen_time.regenerate"), regenerate_screen_time_token_path, method: :post,
              class: "rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50",
              form: { data: { turbo_confirm: t("screen_time.regenerate_confirm") } } %>
      </div>
      <p class="text-xs text-slate-400"><%= t("screen_time.guide") %></p>
    </div>
  </section>
</div>
