<div class="mx-auto max-w-3xl space-y-8">
  <div>
    <h1 class="mb-1 text-2xl font-bold text-slate-900"><%= t("memberships.title", account: @account.name) %></h1>
    <p class="text-sm text-slate-500">
      <%= t("memberships.code_label") %>
      <span class="rounded bg-slate-100 px-2 py-0.5 font-mono"><%= @account.join_code %></span>
      <span class="text-slate-400"><%= t("memberships.code_share") %></span>
    </p>
  </div>

  <section>
    <h2 class="mb-3 text-lg font-semibold text-slate-900"><%= t("memberships.pending_section") %></h2>
    <% if @pending_memberships.any? %>
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-slate-100">
            <% @pending_memberships.each do |m| %>
              <tr>
                <td class="px-3 py-2"><%= m.user.name %> <span class="text-slate-400">(<%= m.user.email %>)</span></td>
                <td class="px-3 py-2 text-right">
                  <div class="flex justify-end gap-2">
                    <%= button_to t("memberships.approve"), account_member_path(@account, m), method: :patch, params: { approve: 1 },
                          class: "rounded bg-emerald-600 px-3 py-1 text-xs font-semibold text-white hover:bg-emerald-700" %>
                    <%= button_to t("memberships.reject"), account_member_path(@account, m), method: :delete,
                          class: "rounded bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700 hover:bg-rose-200",
                          data: { turbo_confirm: t("memberships.reject_confirm") } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-slate-400"><%= t("memberships.no_pending") %></p>
    <% end %>
  </section>

  <section>
    <h2 class="mb-3 text-lg font-semibold text-slate-900"><%= t("memberships.active_section") %></h2>
    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-xs uppercase text-slate-500">
          <tr>
            <th class="px-3 py-2 text-left"><%= t("memberships.col_user") %></th>
            <th class="px-3 py-2 text-center"><%= t("memberships.col_role") %></th>
            <th class="px-3 py-2 text-right"><%= t("memberships.col_actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @active_memberships.each do |m| %>
            <tr>
              <td class="px-3 py-2"><%= m.user.name %> <span class="text-slate-400">(<%= m.user.email %>)</span></td>
              <td class="px-3 py-2 text-center">
                <span class="rounded bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700"><%= m.role %></span>
              </td>
              <td class="px-3 py-2 text-right">
                <% unless m.owner? %>
                  <div class="flex justify-end gap-2">
                    <% if m.role == "member" %>
                      <%= button_to t("memberships.make_admin"), account_member_path(@account, m), method: :patch, params: { role: "admin" },
                            class: "rounded bg-slate-800 px-3 py-1 text-xs text-white hover:bg-slate-900" %>
                    <% else %>
                      <%= button_to t("memberships.make_member"), account_member_path(@account, m), method: :patch, params: { role: "member" },
                            class: "rounded bg-slate-200 px-3 py-1 text-xs text-slate-800 hover:bg-slate-300" %>
                    <% end %>
                    <%= button_to t("memberships.remove"), account_member_path(@account, m), method: :delete,
                          class: "rounded bg-rose-100 px-3 py-1 text-xs text-rose-700 hover:bg-rose-200",
                          data: { turbo_confirm: t("memberships.remove_confirm") } %>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
