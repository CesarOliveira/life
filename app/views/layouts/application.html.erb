<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <title>Life</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# PWA / instalar na tela de início %>
    <meta name="theme-color" content="#10b981">
    <meta name="application-name" content="Life">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Life">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#10b981">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>
  <body data-controller="pwa-install" class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <% if user_signed_in? %>
      <nav class="sticky top-0 z-20 border-b border-slate-200 bg-white/80 backdrop-blur">
        <div class="mx-auto flex h-14 max-w-5xl items-center justify-between gap-2 px-4">
          <div class="flex items-center gap-1">
            <%= link_to authenticated_root_path, class: "mr-3 flex items-center gap-2 font-semibold text-slate-900" do %>
              <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-500 text-sm text-white">✦</span>
              <span>Life</span>
            <% end %>
            <% if current_account %>
              <%= nav_link t("nav.dashboard"), authenticated_root_path %>
              <%= nav_link t("nav.habits"), habits_path %>
              <%= nav_link t("nav.weight"), weights_path %>
              <%= nav_link t("nav.screen_time"), screen_time_path %>
            <% end %>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex items-center overflow-hidden rounded-lg border border-slate-200 text-xs">
              <% I18n.available_locales.each do |loc| %>
                <%= link_to locale_label(loc), locale_switch_path(loc),
                      class: "px-2 py-1 #{I18n.locale == loc ? "bg-emerald-50 font-semibold text-emerald-700" : "text-slate-500 hover:bg-slate-50"}" %>
              <% end %>
            </div>
            <% if current_account %>
              <details class="relative">
                <summary class="flex cursor-pointer list-none select-none items-center gap-1 rounded-lg border border-slate-200 px-3 py-1.5 text-sm text-slate-600 hover:bg-slate-50">
                  <span class="font-medium text-slate-900"><%= current_account.name %></span>
                  <span class="text-slate-400">▾</span>
                </summary>
                <div class="absolute right-0 z-10 mt-2 min-w-[220px] rounded-xl border border-slate-200 bg-white py-1 shadow-lg">
                  <%= link_to t("nav.account_settings"), edit_account_path(current_account), class: "block px-3 py-1.5 text-sm hover:bg-slate-50" %>
                  <button type="button" data-pwa-install-target="menuItem" data-action="pwa-install#promptInstall"
                          class="block w-full px-3 py-1.5 text-left text-sm hover:bg-slate-50">
                    <%= t("pwa.menu_item") %>
                  </button>
                </div>
              </details>
            <% end %>
            <% if current_user&.platform_admin? %>
              <%= link_to t("nav.admin"), admin_root_path, class: "hidden rounded-lg px-3 py-1.5 text-sm font-medium text-slate-500 hover:bg-slate-100 hover:text-slate-900 sm:inline" %>
            <% end %>
            <% if current_user&.super_admin? %>
              <%= link_to t("nav.super_admin"), "/super_admin", class: "hidden rounded-lg px-3 py-1.5 text-sm font-medium text-slate-500 hover:bg-slate-100 hover:text-slate-900 sm:inline" %>
            <% end %>
            <%= link_to t("nav.logout"), destroy_user_session_path, data: { turbo_method: :delete }, class: "rounded-lg px-3 py-1.5 text-sm font-medium text-slate-500 hover:bg-slate-100 hover:text-slate-900" %>
          </div>
        </div>
      </nav>
    <% end %>
    <main class="mx-auto max-w-5xl px-4 py-8">
      <% flash.each do |type, msg| %>
        <div class="mb-4 rounded-xl border px-4 py-3 text-sm <%= type.to_s == "notice" ? "border-emerald-200 bg-emerald-50 text-emerald-800" : "border-rose-200 bg-rose-50 text-rose-800" %>">
          <%= msg %>
        </div>
      <% end %>
      <%= yield %>
    </main>
    <%= render "shared/pwa_install" %>
  </body>
</html>
