<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Admin · Life</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>
  <body class="bg-gray-100 text-gray-900">
    <nav class="bg-gray-900 text-white px-6 py-3 flex items-center justify-between">
      <div class="flex items-center gap-6">
        <%= link_to "⚙ Admin", admin_root_path, class: "font-bold text-lg" %>
        <%= link_to "Aprovações", admin_root_path, class: "text-sm hover:underline" %>
        <%= link_to "Usuários", admin_users_path, class: "text-sm hover:underline" %>
        <%= link_to "Contas", admin_accounts_path, class: "text-sm hover:underline" %>
      </div>
      <div class="flex items-center gap-4">
        <%= link_to "← Voltar ao app", authenticated_root_path, class: "text-sm hover:underline" %>
        <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm hover:underline" %>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto px-4 py-6">
      <% flash.each do |type, msg| %>
        <div class="mb-4 px-4 py-2 rounded <%= type == 'notice' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
          <%= msg %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
