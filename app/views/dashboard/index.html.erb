<div class="space-y-6">
  <header>
    <h1 class="text-2xl font-bold text-slate-900"><%= t("dashboard.greeting", name: current_user.name.split.first) %></h1>
    <p class="text-sm text-slate-500"><%= l(@today, format: :long) %></p>
  </header>

  <div class="grid gap-3 sm:gap-4 <%= @github_yesterday ? "grid-cols-2 sm:grid-cols-4" : "grid-cols-3" %>">
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("dashboard.today") %></p>
      <p class="mt-1 text-2xl font-bold text-slate-900">
        <%= @today_done %><span class="text-base font-medium text-slate-400">/<%= @today_habits.size %></span>
      </p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("dashboard.streak") %></p>
      <p class="mt-1 text-2xl font-bold text-slate-900">🔥 <%= @best_streak %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("dashboard.completions") %></p>
      <p class="mt-1 text-2xl font-bold text-slate-900"><%= @graph.total %></p>
    </div>
    <% if @github_yesterday %>
      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= t("dashboard.github_yesterday") %></p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= @github_yesterday %></p>
      </div>
    <% end %>
  </div>

  <%# Atividade do ano (grade estilo GitHub) com seletor de ano %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
      <h2 class="font-semibold text-slate-900">
        <%= t("activity.summary", count: number_with_delimiter(@graph.total), period: t("activity.period_year", year: @year)) %>
      </h2>
      <div class="flex flex-wrap gap-1.5">
        <% @years.each do |y| %>
          <%= link_to y, root_path(year: y),
                class: "rounded-lg px-3 py-1 text-xs font-medium #{y == @year ? 'bg-emerald-600 text-white' : 'text-slate-500 hover:bg-slate-100'}" %>
        <% end %>
      </div>
    </div>
    <%= render "shared/contributions", graph: @graph %>
  </section>

  <%# Hábitos de hoje %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="font-semibold text-slate-900"><%= t("dashboard.habits_today") %></h2>
      <%= link_to t("dashboard.see_all"), habits_path, class: "text-sm font-medium text-emerald-600 hover:text-emerald-700" %>
    </div>

    <% if @today_habits.empty? %>
      <p class="text-sm text-slate-500">
        <%= t("dashboard.none_today") %>
        <%= link_to t("dashboard.create_a_habit"), new_habit_path, class: "font-medium text-emerald-600 hover:text-emerald-700" %>.
      </p>
    <% else %>
      <ul class="divide-y divide-slate-100">
        <% @today_habits.each do |h| %>
          <% done = @stats[h].done_today? %>
          <% check_classes = done ? "border-emerald-500 bg-emerald-500 text-white" : "border-slate-300 text-transparent" %>
          <li class="flex items-center gap-3 py-2.5">
            <% if h.auto? %>
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border-2 <%= check_classes %>" title="<%= t("habits.auto_badge_hint") %>">
                <span class="text-xs leading-none">✓</span>
              </span>
            <% else %>
              <%= button_to toggle_habit_path(h), params: { date: @today.iso8601 },
                    class: "flex h-7 w-7 shrink-0 cursor-pointer items-center justify-center rounded-full border-2 transition #{check_classes} #{done ? "" : "hover:border-emerald-400"}" do %>
                <span class="text-xs leading-none">✓</span>
              <% end %>
            <% end %>
            <span class="h-3 w-3 shrink-0 rounded-full" style="background-color: <%= h.color %>"></span>
            <span class="text-sm <%= "text-slate-400 line-through" if done %>"><%= h.name %></span>
            <% if h.habit_category %>
              <span class="shrink-0 rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-medium text-slate-500"><%= h.habit_category.name %></span>
            <% end %>
            <% if h.auto? %>
              <span class="shrink-0 rounded-full bg-indigo-50 px-2 py-0.5 text-[10px] font-medium text-indigo-500"><%= t("habits.auto_badge") %></span>
            <% end %>
            <span class="ml-auto shrink-0 text-xs text-slate-400" title="<%= t("habits.streak_tooltip") %>">🔥 <%= @stats[h].current_streak %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>

  <%# Visão geral do ano: radar por categoria %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="mb-1 font-semibold text-slate-900"><%= t("activity.overview") %></h2>
    <p class="mb-4 text-xs text-slate-500"><%= t("activity.overview_hint") %></p>
    <% if @category_total.positive? %>
      <div class="relative mx-auto h-72 max-w-md">
        <canvas data-controller="radar-chart"
                data-radar-chart-labels-value="<%= @category_stats.map { |c| c[:label] }.to_json %>"
                data-radar-chart-counts-value="<%= @category_stats.map { |c| c[:count] }.to_json %>"
                data-radar-chart-percents-value="<%= @category_stats.map { |c| c[:pct] }.to_json %>"></canvas>
      </div>
    <% else %>
      <p class="text-sm text-slate-500"><%= t("activity.overview_empty") %></p>
    <% end %>
  </section>
</div>
