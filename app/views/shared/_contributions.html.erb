<%# locals: graph (ContributionGraph) — célula 12px + gap 4px = coluna de 16px. %>
<%# O balão vive fora do container com scroll (não é cortado nas bordas). %>
<div class="relative" data-controller="tooltip">
  <div data-tooltip-target="bubble"
       class="pointer-events-none absolute z-10 hidden max-w-56 whitespace-pre-line rounded-lg bg-slate-900 px-2.5 py-1.5 text-center text-[11px] leading-snug text-white shadow-lg"></div>
  <%# scroll-end: abre já rolado até a semana atual (útil no celular) %>
  <div class="overflow-x-auto" data-controller="scroll-end">
    <div class="mx-auto w-fit">

    <%# rótulos de mês (largura = semanas * 16px; esconde rótulo de segmento estreito) %>
    <div class="mb-1 flex pl-8">
      <% graph.month_segments.each do |seg| %>
        <div class="shrink-0 overflow-hidden whitespace-nowrap text-[10px] text-slate-400" style="width: <%= seg[:weeks] * 16 %>px">
          <%= seg[:label] if seg[:weeks] >= 3 %>
        </div>
      <% end %>
    </div>

    <div class="flex">
      <%# rótulos de dia da semana (seg, qua, sex) %>
      <div class="flex w-8 shrink-0 flex-col gap-1 pr-1 text-[9px] leading-3 text-slate-400">
        <span class="h-3"></span>
        <span class="h-3"><%= t("date.abbr_day_names")[1].capitalize %></span>
        <span class="h-3"></span>
        <span class="h-3"><%= t("date.abbr_day_names")[3].capitalize %></span>
        <span class="h-3"></span>
        <span class="h-3"><%= t("date.abbr_day_names")[5].capitalize %></span>
        <span class="h-3"></span>
      </div>

      <%# colunas (semanas) %>
      <div class="flex gap-1">
        <% graph.columns.each do |col| %>
          <div class="flex flex-col gap-1">
            <% col.each do |cell| %>
              <% if cell %>
                <% content = t("contributions.cell", date: l(cell.date, format: :long), count: cell.count) %>
                <% content += "\n#{cell.names.join(", ")}" if cell.names.any? %>
                <span class="h-3 w-3 rounded-sm <%= graph.cell_class(cell.level) %>"
                      data-tooltip-content="<%= content %>"
                      data-action="mouseenter->tooltip#show mouseleave->tooltip#hide click->tooltip#show"></span>
              <% else %>
                <span class="h-3 w-3"></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# legenda %>
    <div class="flex items-center justify-end gap-1 pt-2 text-[10px] text-slate-400">
      <span><%= t("contributions.less") %></span>
      <% (0..4).each do |lvl| %>
        <span class="h-3 w-3 rounded-sm <%= graph.cell_class(lvl) %>"></span>
      <% end %>
      <span><%= t("contributions.more") %></span>
    </div>
    </div>
  </div>
</div>
