<%# locals: graph (ContributionGraph) %>
<div class="overflow-x-auto">
  <div class="inline-block">
    <%# rótulos de mês %>
    <div class="flex pl-7 mb-1">
      <% graph.month_segments.each do |seg| %>
        <div class="text-[10px] text-slate-400 whitespace-nowrap shrink-0" style="width: <%= seg[:weeks] * 14 %>px">
          <%= seg[:label] %>
        </div>
      <% end %>
    </div>

    <div class="flex">
      <%# rótulos de dia da semana %>
      <div class="flex flex-col gap-1 pr-1 w-7 shrink-0 text-[9px] leading-[10px] text-slate-400">
        <span class="h-2.5"></span>
        <span class="h-2.5">Seg</span>
        <span class="h-2.5"></span>
        <span class="h-2.5">Qua</span>
        <span class="h-2.5"></span>
        <span class="h-2.5">Sex</span>
        <span class="h-2.5"></span>
      </div>

      <%# colunas (semanas) %>
      <div class="flex gap-1">
        <% graph.columns.each do |col| %>
          <div class="flex flex-col gap-1">
            <% col.each do |cell| %>
              <% if cell %>
                <span class="w-2.5 h-2.5 rounded-sm <%= graph.cell_class(cell.level) %>"
                      title="<%= cell.date.strftime("%d/%m/%Y") %> — <%= cell.count %> hábito(s) concluído(s)"></span>
              <% else %>
                <span class="w-2.5 h-2.5"></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# legenda %>
    <div class="flex items-center justify-end gap-1 pt-2 text-[10px] text-slate-400">
      <span>Menos</span>
      <% (0..4).each do |lvl| %>
        <span class="w-2.5 h-2.5 rounded-sm <%= graph.cell_class(lvl) %>"></span>
      <% end %>
      <span>Mais</span>
    </div>
  </div>
</div>
