<div data-controller="pwa-install">
  <div data-pwa-install-target="banner"
       class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-slate-200 bg-white/95 px-4 py-3 shadow-lg backdrop-blur"
       style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom))">
    <div class="mx-auto flex max-w-5xl items-center gap-3">
      <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-emerald-500 text-white">✦</span>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-semibold text-slate-900"><%= t("pwa.title") %></p>
        <p class="text-xs text-slate-500" data-pwa-install-target="hint" data-ios-text="<%= t("pwa.hint_ios") %>">
          <%= t("pwa.hint_android") %>
        </p>
      </div>
      <button type="button" data-pwa-install-target="installButton" data-action="pwa-install#install"
              class="hidden shrink-0 rounded-lg bg-emerald-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-emerald-700">
        <%= t("pwa.install") %>
      </button>
      <button type="button" data-action="pwa-install#dismiss" aria-label="<%= t("pwa.dismiss") %>"
              class="shrink-0 rounded-lg p-1.5 text-slate-400 hover:bg-slate-100">✕</button>
    </div>
  </div>
</div>
